<div class="section-background color-{{ section.settings.color_scheme }}"></div>

<div
  class="section section--full-width color-{{ section.settings.color_scheme }} pa-brand-feature spacing-style{% if section.settings.image_position == 'right' %} pa-brand-feature--image-right{% endif %}"
  style="{% render 'spacing-style', settings: section.settings %}"
>

  <div class="pa-brand-feature__image-col">
    {%- if section.settings.image != blank -%}
      <img
        src="{{ section.settings.image | image_url: width: 1200 }}"
        alt="{{ section.settings.heading | escape }}"
        class="pa-brand-feature__image"
        loading="lazy"
        width="1200"
        height="1400"
      >
    {%- else -%}
      {{ 'lifestyle-1' | placeholder_svg_tag: 'pa-brand-feature__image pa-brand-feature__image--placeholder' }}
    {%- endif -%}
  </div>

  <div class="pa-brand-feature__content-col">
    <div class="pa-brand-feature__content">
      {%- if section.settings.label != blank -%}
        <p class="pa-brand-feature__label">{{ section.settings.label }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="pa-brand-feature__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.description != blank -%}
        <p class="pa-brand-feature__desc">{{ section.settings.description }}</p>
      {%- endif -%}
      {%- if section.settings.button_label != blank and section.settings.button_url != blank -%}
        <a href="{{ section.settings.button_url }}" class="pa-brand-feature__btn">
          {{ section.settings.button_label }}
        </a>
      {%- endif -%}
    </div>
  </div>

</div>

<style>
  .pa-brand-feature {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 540px;
  }

  /* Image right variant */
  .pa-brand-feature--image-right .pa-brand-feature__image-col {
    order: 2;
  }
  .pa-brand-feature--image-right .pa-brand-feature__content-col {
    order: 1;
  }

  /* ── Image column ── */
  .pa-brand-feature__image-col {
    position: relative;
    overflow: hidden;
  }

  .pa-brand-feature__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }

  .pa-brand-feature__image--placeholder {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  /* ── Content column ── */
  .pa-brand-feature__content-col {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 60px 48px;
  }

  .pa-brand-feature__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 20px;
    max-width: 480px;
  }

  /* ── Text elements ── */
  .pa-brand-feature__label {
    margin: 0;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #EF4B37;
  }

  .pa-brand-feature__heading {
    margin: 0;
    font-size: clamp(32px, 4vw, 60px);
    font-weight: 400;
    line-height: 1.05;
    color: var(--color-foreground);
  }

  .pa-brand-feature__desc {
    margin: 0;
    font-size: 15px;
    line-height: 1.7;
    color: #828282;
    max-width: 400px;
  }

  /* ── Button ── */
  .pa-brand-feature__btn {
    display: inline-block;
    margin-top: 4px;
    padding: 14px 36px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--color-foreground);
    background: transparent;
    border: 1.5px solid var(--color-foreground);
    border-radius: 4px;
    transition: background 0.2s ease, color 0.2s ease;
  }

  .pa-brand-feature__btn:hover {
    background: var(--color-foreground);
    color: var(--color-background);
  }

  /* ── Mobile ── */
  @media (max-width: 749px) {
    .pa-brand-feature {
      grid-template-columns: 1fr;
      min-height: unset;
    }

    .pa-brand-feature__image-col {
      aspect-ratio: 4 / 3;
      position: relative;
    }

    .pa-brand-feature--image-right .pa-brand-feature__image-col,
    .pa-brand-feature--image-right .pa-brand-feature__content-col {
      order: unset;
    }

    .pa-brand-feature__content-col {
      padding: 40px 24px;
    }
  }
</style>

{% schema %}
{
  "name": "PA Brand Feature",
  "tag": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image position",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "MODERN HERITAGE REDEFINED"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Brand Name",
      "default": "Brand Name"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "A short description about the brand and what makes it special."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "EXPLORE COLLECTION"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button Link"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "PA Brand Feature",
      "settings": {
        "label": "MODERN HERITAGE REDEFINED",
        "heading": "Brand Name",
        "description": "A short description about the brand and what makes it special.",
        "button_label": "EXPLORE COLLECTION",
        "image_position": "left"
      }
    }
  ]
}
{% endschema %}
