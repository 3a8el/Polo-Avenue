{% comment %}
  POLO AVENUE — New Arrivals / Just In
  Section: pa-arrivals.liquid
{% endcomment %}

<section class="pa-arrivals">
  <div class="pa-container">
    <div class="pa-arrivals__header">
      <div>
        <p class="pa-label">{{ section.settings.label }}</p>
        <h2 class="pa-section-heading">{{ section.settings.heading }}</h2>
      </div>
      {%- if section.settings.collection != blank -%}
        <a href="{{ section.settings.collection.url }}" class="pa-explore-all">
          EXPLORE ALL
        </a>
      {%- endif -%}
    </div>

    <div class="pa-arrivals__grid">
      {%- assign collection = collections[section.settings.collection] -%}
      {%- assign product_limit = section.settings.product_count | default: 4 -%}

      {%- if collection != blank and collection.products_count > 0 -%}
        {%- for product in collection.products limit: product_limit -%}
          <div class="pa-product-card">
            <div class="pa-product-card__image-wrap">
              {%- if product.featured_image -%}
                <img
                  src="{{ product.featured_image | image_url: width: 600 }}"
                  alt="{{ product.featured_image.alt | escape | default: product.title }}"
                  loading="lazy"
                  width="600"
                >
              {%- else -%}
                {{ 'product-1' | placeholder_svg_tag }}
              {%- endif -%}

              <div class="pa-product-card__nav">
                <button class="pa-product-card__nav-btn" aria-label="Previous image">‹</button>
                <button class="pa-product-card__nav-btn" aria-label="Next image">›</button>
              </div>

              <button
                class="pa-product-card__add"
                data-product-id="{{ product.variants.first.id }}"
                onclick="addToCart('{{ product.variants.first.id }}')"
              >
                ADD TO CART
              </button>
            </div>

            <div class="pa-product-card__info">
              {%- assign color_tag = product.tags | where: "color" | first -%}
              <p class="pa-product-card__color">
                {%- if product.metafields.custom.color_name != blank -%}
                  {{ product.metafields.custom.color_name }}
                {%- elsif color_tag != blank -%}
                  {{ color_tag | remove: 'color:' | upcase }}
                {%- else -%}
                  &nbsp;
                {%- endif -%}
              </p>
              <div class="pa-product-card__bottom">
                <a href="{{ product.url }}" class="pa-product-card__name">
                  {{ product.title }}
                </a>
                <span class="pa-product-card__price">
                  {{ product.price | money_without_trailing_zeros }}
                </span>
              </div>
            </div>
          </div>
        {%- endfor -%}

      {%- else -%}
        {%- comment %} Fallback placeholder cards in theme editor {%- endcomment %}
        {%- for i in (1..4) -%}
          <div class="pa-product-card">
            <div class="pa-product-card__image-wrap">
              {{ 'product-' | append: i | placeholder_svg_tag }}
            </div>
            <div class="pa-product-card__info">
              <p class="pa-product-card__color">SAMPLE COLOR</p>
              <div class="pa-product-card__bottom">
                <span class="pa-product-card__name">Product Name</span>
                <span class="pa-product-card__price">₿ 6,200</span>
              </div>
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

<script>
  function addToCart(variantId) {
    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: variantId, quantity: 1 })
    })
    .then(res => res.json())
    .then(data => {
      // Trigger cart drawer open if theme supports it
      document.dispatchEvent(new CustomEvent('cart:open'));
      // Or redirect to cart
      // window.location.href = '/cart';
    })
    .catch(err => console.error('Add to cart error:', err));
  }
</script>

{% schema %}
{
  "name": "PA New Arrivals",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Eyebrow Label",
      "default": "NEW ARRIVALS"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Just In"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "product_count",
      "min": 2,
      "max": 8,
      "step": 1,
      "label": "Number of Products",
      "default": 4
    }
  ],
  "presets": [
    {
      "name": "PA New Arrivals"
    }
  ]
}
{% endschema %}
