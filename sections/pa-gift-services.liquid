<div class="section-background color-{{ section.settings.color_scheme }}"></div>

<div
  class="section section--page-width color-{{ section.settings.color_scheme }} pa-gift-services spacing-style"
  style="{% render 'spacing-style', settings: section.settings %}"
>
  <div class="pa-gift-services__inner">

    <div class="pa-gift-services__header">
      {%- if section.settings.label != blank -%}
        <p class="pa-gift-services__label">{{ section.settings.label }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h1 class="pa-gift-services__heading">{{ section.settings.heading }}</h1>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="pa-gift-services__subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    <div class="pa-gift-services__grid">
      {%- for block in section.blocks -%}
        <div class="pa-gift-services__card" {{ block.shopify_attributes }}>
          <span class="pa-gift-services__card-dot" aria-hidden="true"></span>
          {%- if block.settings.title != blank -%}
            <h3 class="pa-gift-services__card-title">{{ block.settings.title }}</h3>
          {%- endif -%}
          {%- if block.settings.description != blank -%}
            <p class="pa-gift-services__card-desc">{{ block.settings.description }}</p>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>

  </div>
</div>

<style>
  .pa-gift-services__inner {
    display: flex;
    flex-direction: column;
    gap: 48px;
  }

  /* ── Header ── */
  .pa-gift-services__header {
    display: flex;
    flex-direction: column;
    gap: 12px;
    max-width: 640px;
  }

  .pa-gift-services__label {
    margin: 0;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #EF4B37;
  }

  .pa-gift-services__heading {
    margin: 0;
    font-size: clamp(28px, 4vw, 52px);
    font-weight: 400;
    line-height: 1.1;
    color: var(--color-foreground);
  }

  .pa-gift-services__subheading {
    margin: 0;
    font-size: 15px;
    line-height: 1.65;
    color: var(--color-foreground);
    opacity: 0.6;
  }

  /* ── Cards grid ── */
  .pa-gift-services__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    border-top: 1px solid rgba(0,0,0,0.08);
    padding-top: 40px;
  }

  /* ── Single card ── */
  .pa-gift-services__card {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .pa-gift-services__card-dot {
    display: block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #EF4B37;
    flex-shrink: 0;
  }

  .pa-gift-services__card-title {
    margin: 0;
    font-size: 16px;
    font-weight: 500;
    line-height: 1.3;
    color: var(--color-foreground);
  }

  .pa-gift-services__card-desc {
    margin: 0;
    font-size: 14px;
    line-height: 1.65;
    color: var(--color-foreground);
    opacity: 0.6;
  }

  /* ── Mobile ── */
  @media (max-width: 989px) {
    .pa-gift-services__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 32px 24px;
    }
  }

  @media (max-width: 749px) {
    .pa-gift-services__inner {
      gap: 32px;
    }

    .pa-gift-services__grid {
      grid-template-columns: 1fr;
      gap: 28px;
    }
  }
</style>

{% schema %}
{
  "name": "PA Gift Services",
  "tag": "section",
  "max_blocks": 8,
  "blocks": [
    {
      "type": "service",
      "name": "Service Card",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Service Title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "A short description of this service."
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "GIFT SERVICES"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Art of Giving"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Every gift from Polo Avenue arrives in our signature luxury packaging, wrapped with care, and delivered with intent."
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "PA Gift Services",
      "blocks": [
        {
          "type": "service",
          "settings": {
            "title": "Luxury Gift Wrapping",
            "description": "Every order arrives in our signature luxury packaging, handwritten note included with every gift."
          }
        },
        {
          "type": "service",
          "settings": {
            "title": "Gift Cards",
            "description": "From AED 500–AED 5000+ in physical or digital format. Perfect for every occasion."
          }
        },
        {
          "type": "service",
          "settings": {
            "title": "Gift Consultation",
            "description": "Our stylists will curate the perfect gift for your recipient's taste and budget."
          }
        },
        {
          "type": "service",
          "settings": {
            "title": "Same-Day Delivery",
            "description": "Order before 12pm in Dubai. Order before 12pm for same-day delivery."
          }
        }
      ]
    }
  ]
}
{% endschema %}
