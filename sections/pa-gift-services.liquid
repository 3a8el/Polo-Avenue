<div class="section-background color-{{ section.settings.color_scheme }}"></div>

<div
  class="section section--full-width color-{{ section.settings.color_scheme }} pa-gift-services spacing-style"
  style="{% render 'spacing-style', settings: section.settings %}"
>

  {%- comment -%} ── Section 1: Image hero header ── {%- endcomment -%}
  <div class="pa-gift-services__hero">
    {%- if section.settings.hero_image != blank -%}
      <img
        src="{{ section.settings.hero_image | image_url: width: 2400 }}"
        alt="{{ section.settings.heading | escape }}"
        class="pa-gift-services__hero-image"
        loading="eager"
        width="2400"
        height="1200"
      >
    {%- else -%}
      {{ 'lifestyle-2' | placeholder_svg_tag: 'pa-gift-services__hero-image pa-gift-services__hero-image--placeholder' }}
    {%- endif -%}

    <div class="pa-gift-services__hero-overlay"></div>

    <div class="pa-gift-services__hero-content">
      {%- if section.settings.label != blank -%}
        <p class="pa-gift-services__label">{{ section.settings.label }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h1 class="pa-gift-services__heading">{{ section.settings.heading }}</h1>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="pa-gift-services__subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>
  </div>

  {%- comment -%} ── Section 2: Service cards ── {%- endcomment -%}
  <div class="pa-gift-services__cards-wrap">
    <div class="pa-gift-services__grid">
      {%- for block in section.blocks -%}
        <div class="pa-gift-services__card" {{ block.shopify_attributes }}>
          <span class="pa-gift-services__card-icon" aria-hidden="true">
            {{- 'pa-star.svg' | inline_asset_content -}}
          </span>
          {%- if block.settings.title != blank -%}
            <h3 class="pa-gift-services__card-title">{{ block.settings.title }}</h3>
          {%- endif -%}
          {%- if block.settings.description != blank -%}
            <p class="pa-gift-services__card-desc">{{ block.settings.description }}</p>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>

</div>

<style>
  .pa-gift-services {
    padding: 0 !important;
  }

  /* ── Hero ── */
  .pa-gift-services__hero {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 7;
    overflow: hidden;
    min-height: 320px;
  }

  .pa-gift-services__hero-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .pa-gift-services__hero-image--placeholder {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .pa-gift-services__hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to right, rgba(0,0,0,0.55) 0%, rgba(0,0,0,0.15) 60%, transparent 100%);
  }

  .pa-gift-services__hero-content {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    gap: 12px;
    padding: 48px 60px;
    max-width: 640px;
  }

  .pa-gift-services__label {
    margin: 0;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #EF4B37;
  }

  .pa-gift-services__heading {
    margin: 0;
    font-size: clamp(28px, 4vw, 56px);
    font-weight: 400;
    line-height: 1.05;
    color: #ffffff;
    border: none;
    text-decoration: none;
  }

  .pa-gift-services__subheading {
    margin: 0;
    font-size: 15px;
    line-height: 1.65;
    color: rgba(255,255,255,0.8);
    max-width: 480px;
  }

  /* ── Cards wrap ── */
  .pa-gift-services__cards-wrap {
    padding-block: 60px;
    padding-inline: 60px;
  }

  /* ── Cards grid ── */
  .pa-gift-services__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 28px;
  }

  /* ── Single card ── */
  .pa-gift-services__card {
    display: flex;
    flex-direction: column;
    gap: 0;
    background: #FAF9F7;
    border-top: 2px solid #EF4B37;
    border-radius: 0 0 8px 8px;
    padding: 20px 20px 80px;
  }

  .pa-gift-services__card-icon {
    display: flex;
    align-items: center;
    margin-bottom: 8px;
    flex-shrink: 0;
  }

  .pa-gift-services__card-icon svg {
    width: 16px;
    height: 16px;
    display: block;
  }

  .pa-gift-services__card-title {
    margin: 0 0 4px;
    font-family: 'Montserrat', var(--font-body--family), sans-serif;
    font-size: 16px !important;
    font-weight: 600 !important;
    letter-spacing: 0 !important;
    line-height: 1.3;
    color: #1A1A1A !important;
    text-transform: none !important;
  }

  .pa-gift-services__card-desc {
    margin: 0;
    font-size: 14px;
    font-weight: 400;
    line-height: 1.6;
    letter-spacing: 0.004em;
    color: #828282;
  }

  /* ── Mobile ── */
  @media (max-width: 989px) {
    .pa-gift-services__grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .pa-gift-services__hero-content {
      padding: 32px 40px;
    }
  }

  @media (max-width: 749px) {
    .pa-gift-services__hero {
      aspect-ratio: 4 / 3;
    }

    .pa-gift-services__hero-content {
      padding: 24px;
    }

    .pa-gift-services__cards-wrap {
      padding-block: 40px;
      padding-inline: 24px;
    }

    .pa-gift-services__card {
      padding-bottom: 48px;
    }

    .pa-gift-services__grid {
      grid-template-columns: 1fr;
      gap: 16px;
    }
  }
</style>

{% schema %}
{
  "name": "PA Gift Services",
  "tag": "section",
  "max_blocks": 8,
  "blocks": [
    {
      "type": "service",
      "name": "Service Card",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Service Title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "A short description of this service."
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero Background Image"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "GIFT SERVICES"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Art of Giving"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Every gift from Polo Avenue arrives in our signature luxury packaging, wrapped with care, and delivered with intent."
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "PA Gift Services",
      "blocks": [
        {
          "type": "service",
          "settings": {
            "title": "Luxury Gift Wrapping",
            "description": "Every order arrives in our signature luxury packaging, handwritten note included with every gift."
          }
        },
        {
          "type": "service",
          "settings": {
            "title": "Gift Cards",
            "description": "From AED 500–AED 5000 Digital or physical. Perfect for every occasion."
          }
        },
        {
          "type": "service",
          "settings": {
            "title": "Gift Consultation",
            "description": "Our stylists will curate the perfect gift for your recipient's taste and budget."
          }
        },
        {
          "type": "service",
          "settings": {
            "title": "Same-Day Delivery",
            "description": "Order before 12pm in Dubai. Order before 12pm for same-day delivery."
          }
        }
      ]
    }
  ]
}
{% endschema %}
