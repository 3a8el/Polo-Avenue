<div class="section-background color-{{ section.settings.color_scheme }}"></div>

<div
  class="section section--page-width color-{{ section.settings.color_scheme }} pa-gift-cols spacing-style"
  style="{% render 'spacing-style', settings: section.settings %}"
>
  <div class="pa-gift-cols__inner">

    <div class="pa-gift-cols__header">
      {%- if section.settings.label != blank -%}
        <p class="pa-gift-cols__label">{{ section.settings.label }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="pa-gift-cols__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
    </div>

    <div class="pa-gift-cols__grid">
      {%- for block in section.blocks -%}
        <div class="pa-gift-cols__card" {{ block.shopify_attributes }}>
          <div class="pa-gift-cols__card-image-wrap">
            {%- if block.settings.image != blank -%}
              <img
                src="{{ block.settings.image | image_url: width: 900 }}"
                alt="{{ block.settings.title | escape }}"
                class="pa-gift-cols__card-image"
                loading="lazy"
                width="900"
                height="1100"
              >
            {%- else -%}
              {{ 'collection-apparel-1' | placeholder_svg_tag: 'pa-gift-cols__card-image pa-gift-cols__card-image--placeholder' }}
            {%- endif -%}
          </div>

          <div class="pa-gift-cols__card-info">
            <div class="pa-gift-cols__card-bottom">
              {%- if block.settings.title != blank -%}
                <h4 class="pa-gift-cols__card-name">{{ block.settings.title }}</h4>
              {%- endif -%}
              {%- if block.settings.collection_url != blank -%}
                <a href="{{ block.settings.collection_url }}" class="pa-gift-cols__card-link">
                  {{ section.settings.card_cta_label | default: 'EXPLORE' }} &rarr;
                </a>
              {%- endif -%}
            </div>
          </div>
        </div>
      {%- endfor -%}
    </div>

  </div>
</div>

<style>
  .pa-gift-cols__inner {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  /* ── Header ── */
  .pa-gift-cols__header {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .pa-gift-cols__label {
    margin: 0;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #EF4B37;
  }

  .pa-gift-cols__heading {
    margin: 0;
    font-size: clamp(24px, 3vw, 40px);
    font-weight: 400;
    line-height: 1.1;
    color: var(--color-foreground);
  }

  /* ── Grid ── */
  .pa-gift-cols__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }

  /* ── Card ── */
  .pa-gift-cols__card {
    position: relative;
    border-radius: 12px;
    overflow: hidden;
    background: var(--color-background);
  }

  .pa-gift-cols__card-image-wrap {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
  }

  .pa-gift-cols__card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    transition: transform 0.5s ease;
  }

  .pa-gift-cols__card:hover .pa-gift-cols__card-image {
    transform: scale(1.04);
  }

  .pa-gift-cols__card-image--placeholder {
    width: 100%;
    height: 100%;
  }

  /* Info panel overlaid at bottom */
  .pa-gift-cols__card-info {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 20px 16px;
    background: rgba(250, 249, 247, 1);
  }

  .pa-gift-cols__card-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
  }

  .pa-gift-cols__card-name {
    margin: 0;
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-foreground);
  }

  .pa-gift-cols__card-link {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #EF4B37;
    text-decoration: none;
    white-space: nowrap;
    transition: opacity 0.2s ease;
  }

  .pa-gift-cols__card-link:hover {
    opacity: 0.7;
  }

  /* ── Mobile ── */
  @media (max-width: 989px) {
    .pa-gift-cols__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
    }
  }

  @media (max-width: 749px) {
    .pa-gift-cols__inner {
      gap: 24px;
    }

    .pa-gift-cols__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 10px;
    }
  }
</style>

{% schema %}
{
  "name": "PA Gift Collections",
  "tag": "section",
  "max_blocks": 8,
  "blocks": [
    {
      "type": "collection_card",
      "name": "Collection Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "FOR HIM"
        },
        {
          "type": "url",
          "id": "collection_url",
          "label": "Collection Link"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "SHOP BY RECIPIENT"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Find the Perfect Gift"
    },
    {
      "type": "text",
      "id": "card_cta_label",
      "label": "Card CTA Label",
      "default": "EXPLORE"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "PA Gift Collections",
      "blocks": [
        { "type": "collection_card", "settings": { "title": "FOR HIM", "collection_url": "/collections/for-him" } },
        { "type": "collection_card", "settings": { "title": "FOR HER", "collection_url": "/collections/for-her" } },
        { "type": "collection_card", "settings": { "title": "FOR THE HOME", "collection_url": "/collections/for-the-home" } },
        { "type": "collection_card", "settings": { "title": "FINE JEWELLERY", "collection_url": "/collections/fine-jewellery" } }
      ]
    }
  ]
}
{% endschema %}
