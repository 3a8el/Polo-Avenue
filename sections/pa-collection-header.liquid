<div class="section-background color-{{ section.settings.color_scheme }}"></div>

<div class="pa-col-header color-{{ section.settings.color_scheme }}">

  <div class="pa-col-header__bg">
    {%- if collection.image != blank -%}
      <img
        src="{{ collection.image | image_url: width: 2400 }}"
        alt="{{ collection.title | escape }}"
        class="pa-col-header__bg-img"
        loading="eager"
        fetchpriority="high"
        width="2400"
        height="800"
      >
    {%- else -%}
      <img
        src="{{ section.settings.fallback_image_desktop }}"
        alt="{{ collection.title | escape }}"
        class="pa-col-header__bg-img pa-col-header__bg-img--desktop"
        loading="eager"
        fetchpriority="high"
        width="2400"
        height="800"
      >
      <img
        src="{{ section.settings.fallback_image_mobile }}"
        alt="{{ collection.title | escape }}"
        class="pa-col-header__bg-img pa-col-header__bg-img--mobile"
        loading="eager"
        fetchpriority="high"
        width="750"
        height="750"
      >
    {%- endif -%}
    <div class="pa-col-header__overlay"></div>
  </div>

  <div class="pa-col-header__content">
    <h1 class="pa-col-header__title">{{ collection.title }}</h1>
    {%- if collection.description != blank -%}
      <p class="pa-col-header__desc">{{ collection.description }}</p>
    {%- endif -%}
  </div>

</div>

<style>
  .pa-col-header {
    position: relative;
    width: 100%;
    min-height: 360px;
    height: 38vw;
    max-height: 520px;
    overflow: hidden;
    display: flex;
    align-items: flex-end;
  }

  /* ── Background ── */
  .pa-col-header__bg {
    position: absolute;
    inset: 0;
  }

  .pa-col-header__bg-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .pa-col-header__bg-img--mobile {
    display: none;
  }

  .pa-col-header__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.55) 0%, rgba(0,0,0,0.15) 50%, transparent 100%);
  }

  /* ── Content ── */
  .pa-col-header__content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 48px 52px;
    max-width: 720px;
  }

  .pa-col-header__title {
    margin: 0;
    font-size: clamp(28px, 4vw, 52px);
    font-weight: 400;
    line-height: 1.05;
    color: #ffffff;
    border: none;
    text-decoration: none;
  }

  .pa-col-header__desc {
    margin: 0;
    font-size: 14px;
    line-height: 1.7;
    color: rgba(255,255,255,0.8);
    max-width: 520px;
  }

  /* ── Mobile ── */
  @media (max-width: 749px) {
    .pa-col-header {
      height: 60vw;
      min-height: 260px;
      max-height: 400px;
    }

    .pa-col-header__content {
      padding: 28px 20px;
    }

    .pa-col-header__bg-img--desktop {
      display: none;
    }

    .pa-col-header__bg-img--mobile {
      display: block;
    }
  }
</style>

{% schema %}
{
  "name": "PA Collection Header",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "fallback_image_desktop",
      "label": "Fallback Image URL (Desktop)",
      "info": "Used when the collection has no image. Paste the CDN URL.",
      "default": "https://cdn.shopify.com/s/files/1/0785/8513/5336/files/hero-PA-cover.webp?v=1776112364"
    },
    {
      "type": "text",
      "id": "fallback_image_mobile",
      "label": "Fallback Image URL (Mobile)",
      "info": "Used on screens ≤749px when the collection has no image.",
      "default": "https://cdn.shopify.com/s/files/1/0785/8513/5336/files/Hero-pa-cover-m.webp?v=1776112430"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-5"
    }
  ],
  "presets": [
    {
      "name": "PA Collection Header"
    }
  ]
}
{% endschema %}
