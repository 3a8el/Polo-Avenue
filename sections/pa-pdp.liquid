{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign product_form_id = 'pa-pdp-form-' | append: section.id
-%}

<div class="pa-pdp color-{{ section.settings.color_scheme }}">
  <div class="pa-pdp__layout">

    <!-- ── Left: Media Gallery ── -->
    <div class="pa-pdp__media">
      <div class="pa-pdp__main-wrap">
        {%- if product.featured_media -%}
          <img
            id="pa-pdp-main"
            src="{{ current_variant.featured_media | default: product.featured_media | image_url: width: 1400 }}"
            alt="{{ product.title | escape }}"
            class="pa-pdp__main-img"
            width="1400"
            loading="eager"
          >
        {%- else -%}
          {{ 'product-1' | placeholder_svg_tag: 'pa-pdp__main-img pa-pdp__main-img--placeholder' }}
        {%- endif -%}
      </div>

      {%- if product.media.size > 1 -%}
        <div class="pa-pdp__thumbs">
          {%- for media in product.media -%}
            <button
              type="button"
              class="pa-pdp__thumb{% if forloop.first %} pa-pdp__thumb--active{% endif %}"
              data-img-src="{{ media | image_url: width: 1400 }}"
              aria-label="{{ media.alt | default: product.title | escape }}"
            >
              <img src="{{ media | image_url: width: 160 }}" alt="" loading="lazy" width="160">
            </button>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    <!-- ── Right: Product Details ── -->
    <div class="pa-pdp__details">

      {%- if product.vendor != blank -%}
        <p class="pa-pdp__vendor">{{ product.vendor }}</p>
      {%- endif -%}

      <h1 class="pa-pdp__title">{{ product.title }}</h1>

      <div class="pa-pdp__price" id="pa-pdp-price">
        {%- render 'price', product_resource: product -%}
      </div>

      <p class="pa-pdp__vat">Inclusive of VAT &middot; Free Delivery</p>

      <div class="pa-pdp__divider"></div>

      {%- unless product.has_only_default_variant -%}
        <div class="pa-pdp__options" id="pa-pdp-options">
          {%- for option in product.options_with_values -%}
            <div class="pa-pdp__option-group">
              <div class="pa-pdp__option-header">
                <span class="pa-pdp__option-label">SELECT {{ option.name | upcase }}</span>
                {%- if option.name == 'Size' or option.name == 'size' -%}
                  <a href="{{ section.settings.size_guide_url | default: '#' }}" class="pa-pdp__size-guide">SIZE GUIDE +</a>
                {%- endif -%}
              </div>
              <div class="pa-pdp__option-values" data-option-position="{{ forloop.index0 }}" data-option-name="{{ option.name | escape }}">
                {%- for value in option.values -%}
                  {%- liquid
                    assign is_selected = false
                    if option.selected_value == value
                      assign is_selected = true
                    endif
                    assign is_color = false
                    if option.name == 'Color' or option.name == 'Colour' or option.name == 'color' or option.name == 'colour'
                      assign is_color = true
                    endif
                  -%}
                  <button
                    type="button"
                    class="pa-pdp__opt-btn{% if is_color %} pa-pdp__opt-btn--swatch{% endif %}{% if is_selected %} is-selected{% endif %}"
                    data-value="{{ value | escape }}"
                    data-option-index="{{ forloop.parentloop.index0 }}"
                  >
                    {%- if is_color -%}
                      <span class="pa-pdp__swatch-inner" style="background-color: {{ value | downcase | replace: ' ', '' | replace: '/', '' }};"></span>
                    {%- else -%}
                      {{ value }}
                    {%- endif -%}
                  </button>
                {%- endfor -%}
              </div>
            </div>
          {%- endfor -%}
        </div>
      {%- endunless -%}

      {%- form 'product', product, id: product_form_id, class: 'pa-pdp__form' -%}
        <input type="hidden" name="id" id="pa-pdp-variant-id" value="{{ current_variant.id }}">
        <input type="hidden" name="quantity" value="1">
        <button type="submit" name="add" class="pa-pdp__atc-btn" id="pa-pdp-atc" {% unless current_variant.available %}disabled{% endunless %}>
          <span class="pa-pdp__atc-text">{%- if current_variant.available -%}ADD TO CART{%- else -%}SOLD OUT{%- endif -%}</span>
        </button>
      {%- endform -%}

      <button type="button" class="pa-pdp__wishlist-btn swym-button swym-add-to-wishlist product_{{ product.id }}" data-swym-variant-id="{{ current_variant.id }}" data-swym-product-id="{{ product.id }}" data-swym-product-url="{{ shop.url }}{{ product.url }}" id="pa-pdp-wishlist">
        ADD TO WISHLIST
      </button>

      <div class="pa-pdp__badges">
        <div class="pa-pdp__badge">
          <p class="pa-pdp__badge-title">{{ section.settings.badge_1_title | default: 'FREE DELIVERY' }}</p>
          <p class="pa-pdp__badge-desc">{{ section.settings.badge_1_desc | default: 'Over AED 400' }}</p>
        </div>
        <div class="pa-pdp__badge-sep"></div>
        <div class="pa-pdp__badge">
          <p class="pa-pdp__badge-title">{{ section.settings.badge_2_title | default: 'AUTHENTICATED' }}</p>
          <p class="pa-pdp__badge-desc">{{ section.settings.badge_2_desc | default: '100% Verified' }}</p>
        </div>
        <div class="pa-pdp__badge-sep"></div>
        <div class="pa-pdp__badge">
          <p class="pa-pdp__badge-title">{{ section.settings.badge_3_title | default: 'EASY RETURNS' }}</p>
          <p class="pa-pdp__badge-desc">{{ section.settings.badge_3_desc | default: '30-day policy' }}</p>
        </div>
      </div>

      <div class="pa-pdp__accordions">
        <details class="pa-pdp__accordion" open>
          <summary class="pa-pdp__accordion-head">
            <span>DESCRIPTION + CARE</span>
            <span class="pa-pdp__accordion-icon" aria-hidden="true"></span>
          </summary>
          <div class="pa-pdp__accordion-body">
            {%- if product.description != blank -%}{{ product.description }}{%- else -%}<p>{{ section.settings.default_description }}</p>{%- endif -%}
          </div>
        </details>
        <details class="pa-pdp__accordion">
          <summary class="pa-pdp__accordion-head">
            <span>DELIVERY &amp; RETURNS</span>
            <span class="pa-pdp__accordion-icon" aria-hidden="true"></span>
          </summary>
          <div class="pa-pdp__accordion-body">
            {{ section.settings.delivery_text | default: 'Complimentary standard delivery on orders over AED 400. Express same-day delivery available in Dubai for AED 85. Return any unworn item within 30 days of delivery.' }}
          </div>
        </details>
        <details class="pa-pdp__accordion">
          <summary class="pa-pdp__accordion-head">
            <span>BOOK A STYLING SESSION</span>
            <span class="pa-pdp__accordion-icon" aria-hidden="true"></span>
          </summary>
          <div class="pa-pdp__accordion-body">
            {{ section.settings.styling_text | default: 'Book a complimentary personal styling session with one of our expert stylists. In-store or virtual appointments available.' }}
          </div>
        </details>
      </div>

      <div class="pa-pdp__styling-cta">
        <p class="pa-pdp__styling-cta-text">Need help with sizing or styling? Book a Personal Styling Session.</p>
        <a href="{{ section.settings.styling_url | default: '/pages/personal-styling' }}" class="pa-pdp__styling-cta-link">BOOK NOW +</a>
      </div>

    </div>
  </div>
</div>

<script id="pa-pdp-variants" type="application/json">{{ product.variants | json }}</script>
<script id="pa-pdp-media-map" type="application/json">
  {
    {%- for variant in product.variants -%}
      {%- if variant.featured_media -%}
        "{{ variant.id }}": "{{ variant.featured_media | image_url: width: 1400 }}"
        {%- unless forloop.last -%},{%- endunless -%}
      {%- endif -%}
    {%- endfor -%}
  }
</script>

<script>
(function() {
  const variantInput = document.getElementById('pa-pdp-variant-id');
  const atcBtn = document.getElementById('pa-pdp-atc');
  const atcText = atcBtn && atcBtn.querySelector('.pa-pdp__atc-text');
  const mainImg = document.getElementById('pa-pdp-main');
  const wishlistBtn = document.getElementById('pa-pdp-wishlist');
  const variants = JSON.parse(document.getElementById('pa-pdp-variants').textContent);
  const mediaMap = JSON.parse(document.getElementById('pa-pdp-media-map').textContent);

  document.querySelectorAll('.pa-pdp__thumb').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.pa-pdp__thumb').forEach(b => b.classList.remove('pa-pdp__thumb--active'));
      btn.classList.add('pa-pdp__thumb--active');
      if (mainImg) mainImg.src = btn.dataset.imgSrc;
    });
  });

  let selectedOptions = [
    {%- for option in product.options_with_values -%}
      {{ option.selected_value | json }}{%- unless forloop.last -%},{%- endunless -%}
    {%- endfor -%}
  ];

  function findVariant(options) {
    return variants.find(v => v.options.every((o, i) => o === options[i])) || null;
  }

  function updateAvailability(variant) {
    if (!variant) { atcBtn.disabled = true; if (atcText) atcText.textContent = 'UNAVAILABLE'; return; }
    variantInput.value = variant.id;
    atcBtn.disabled = !variant.available;
    if (atcText) atcText.textContent = variant.available ? 'ADD TO CART' : 'SOLD OUT';
    if (wishlistBtn) wishlistBtn.dataset.swymVariantId = variant.id;
    if (mainImg && mediaMap[variant.id]) mainImg.src = mediaMap[variant.id];
    const url = new URL(window.location.href);
    url.searchParams.set('variant', variant.id);
    window.history.replaceState({}, '', url.toString());
  }

  document.querySelectorAll('.pa-pdp__opt-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const idx = parseInt(btn.dataset.optionIndex, 10);
      selectedOptions[idx] = btn.dataset.value;
      btn.closest('.pa-pdp__option-values').querySelectorAll('.pa-pdp__opt-btn').forEach(b => b.classList.remove('is-selected'));
      btn.classList.add('is-selected');
      updateAvailability(findVariant(selectedOptions));
    });
  });

  document.querySelectorAll('.pa-pdp__accordion').forEach(details => {
    const icon = details.querySelector('.pa-pdp__accordion-icon');
    if (icon) icon.dataset.open = details.open ? '1' : '0';
    details.addEventListener('toggle', () => { if (icon) icon.dataset.open = details.open ? '1' : '0'; });
  });
})();
</script>

<style>
  .pa-pdp { max-width: var(--page-width, 1400px); margin: 0 auto; padding: 32px 60px 60px; }
  .pa-pdp__layout { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: start; }
  .pa-pdp__media { display: flex; flex-direction: column; gap: 12px; position: sticky; top: calc(var(--header-height, 60px) + 24px); }
  .pa-pdp__main-wrap { width: 100%; aspect-ratio: 3 / 4; overflow: hidden; background: #FAF9F7; }
  .pa-pdp__main-img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .pa-pdp__main-img--placeholder { width: 100%; height: 100%; }
  .pa-pdp__thumbs { display: flex; gap: 8px; overflow-x: auto; scrollbar-width: none; }
  .pa-pdp__thumbs::-webkit-scrollbar { display: none; }
  .pa-pdp__thumb { flex-shrink: 0; width: 72px; height: 90px; border: 2px solid transparent; padding: 0; background: #FAF9F7; cursor: pointer; overflow: hidden; transition: border-color 0.15s; }
  .pa-pdp__thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .pa-pdp__thumb--active, .pa-pdp__thumb:hover { border-color: #1A1A1A; }
  .pa-pdp__details { display: flex; flex-direction: column; gap: 16px; padding-top: 8px; }
  .pa-pdp__vendor { margin: 0; font-size: 12px; font-weight: 700; letter-spacing: 0.3em; text-transform: uppercase; color: #EF4B37; }
  .pa-pdp__title { margin: 0; font-size: 28px; font-weight: 400; line-height: 1.15; color: #1A1A1A; border: none; text-decoration: none; }
  .pa-pdp__price { margin: 0; }
  .pa-pdp__price .price__current, .pa-pdp__price .price, .pa-pdp__price .price-item--regular { font-size: 20px !important; font-weight: 500 !important; color: #1A1A1A !important; }
  .pa-pdp__vat { margin: -8px 0 0; font-size: 10px; color: #B0ACA8; letter-spacing: 0.02em; }
  .pa-pdp__divider { height: 1px; background: #F0EDE7; margin: 0; }
  .pa-pdp__options { display: flex; flex-direction: column; gap: 20px; }
  .pa-pdp__option-group { display: flex; flex-direction: column; gap: 10px; }
  .pa-pdp__option-header { display: flex; align-items: center; justify-content: space-between; }
  .pa-pdp__option-label { font-size: 12px; font-weight: 600; letter-spacing: 0.1em; color: #1A1A1A; }
  .pa-pdp__size-guide { font-size: 12px; font-weight: 700; letter-spacing: 0.12em; color: #EF4B37; text-decoration: none; text-transform: uppercase; }
  .pa-pdp__size-guide:hover { opacity: 0.8; }
  .pa-pdp__option-values { display: flex; flex-wrap: wrap; gap: 8px; }
  .pa-pdp__opt-btn { min-width: 52px; height: 44px; padding: 0 16px; border: 1.5px solid #D0D0D0; border-radius: 8px; background: #fff; font-size: 13px; font-weight: 500; color: #1A1A1A; cursor: pointer; transition: border-color 0.15s, background 0.15s; border-radius: 0; letter-spacing: 0.02em; }
  .pa-pdp__opt-btn:hover { border-color: #1A1A1A; }
  .pa-pdp__opt-btn.is-selected { border-color: #EF4B37; background: #EF4B37; color: #fff; }
  .pa-pdp__opt-btn--disabled { opacity: 0.35; cursor: not-allowed; text-decoration: line-through; }
  .pa-pdp__opt-btn--swatch { width: 36px; height: 36px; min-width: 36px; padding: 3px; border-radius: 50%; }
  .pa-pdp__swatch-inner { display: block; width: 100%; height: 100%; border-radius: 50%; border: 1px solid rgba(0,0,0,0.08); }
  .pa-pdp__opt-btn--swatch.is-selected { border-color: #1A1A1A; background: transparent; }
  .pa-pdp__form { margin: 0; }
  .pa-pdp__atc-btn { width: 100%; padding: 12px; border: none; border-radius: 8px; background: #FAF9F7; font-size: 14px; font-weight: 600; letter-spacing: 0.08em; color: #1A1A1A; cursor: pointer; text-transform: uppercase; transition: background 0.15s, opacity 0.15s; }
  .pa-pdp__atc-btn:hover:not(:disabled) { background: #F0EDE7; }
  .pa-pdp__atc-btn:disabled { opacity: 0.5; cursor: not-allowed; }
  .pa-pdp__wishlist-btn { width: 100%; padding: 12px; border: 1px solid #1A1A1A; border-radius: 8px; background: transparent; font-size: 14px; font-weight: 600; letter-spacing: 0.08em; color: #1A1A1A; cursor: pointer; text-transform: uppercase; transition: background 0.15s; }
  .pa-pdp__wishlist-btn:hover { background: #FAF9F7; }
  .pa-pdp__badges { display: flex; align-items: center; padding: 4px 0; }
  .pa-pdp__badge { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 4px; text-align: center; padding: 0 12px; }
  .pa-pdp__badge:first-child { padding-left: 0; }
  .pa-pdp__badge:last-child { padding-right: 0; }
  .pa-pdp__badge-sep { width: 1px; height: 40px; background: #F0EDE7; flex-shrink: 0; }
  .pa-pdp__badge-title { margin: 0; font-size: 12px; font-weight: 700; color: #1A1A1A; text-transform: uppercase; letter-spacing: 0.04em; }
  .pa-pdp__badge-desc { margin: 0; font-size: 12px; font-weight: 400; line-height: 1.7; letter-spacing: 0.04em; color: #828282; }
  .pa-pdp__accordions { display: flex; flex-direction: column; border-top: 1px solid #F0EDE7; }
  .pa-pdp__accordion { border-bottom: 1px solid #F0EDE7; }
  .pa-pdp__accordion-head { display: flex; align-items: center; justify-content: space-between; padding: 16px 0; cursor: pointer; list-style: none; font-size: 13px; font-weight: 600; letter-spacing: 0.1em; color: #1A1A1A; user-select: none; }
  .pa-pdp__accordion-head::-webkit-details-marker { display: none; }
  .pa-pdp__accordion-icon { width: 18px; height: 18px; position: relative; flex-shrink: 0; }
  .pa-pdp__accordion-icon::before, .pa-pdp__accordion-icon::after { content: ''; position: absolute; background: #1A1A1A; border-radius: 1px; transition: transform 0.2s, opacity 0.2s; }
  .pa-pdp__accordion-icon::before { width: 12px; height: 1.5px; top: 50%; left: 50%; transform: translate(-50%, -50%); }
  .pa-pdp__accordion-icon::after { width: 1.5px; height: 12px; top: 50%; left: 50%; transform: translate(-50%, -50%); }
  .pa-pdp__accordion[open] .pa-pdp__accordion-icon::after { opacity: 0; transform: translate(-50%, -50%) rotate(90deg); }
  .pa-pdp__accordion-body { padding: 0 0 20px; font-size: 14px; line-height: 1.7; color: #828282; }
  .pa-pdp__accordion-body p { margin: 0 0 8px; }
  .pa-pdp__accordion-body p:last-child { margin-bottom: 0; }
  .pa-pdp__styling-cta { display: flex; align-items: center; justify-content: space-between; gap: 16px; background: #FAF9F7; border-radius: 8px; padding: 16px 20px; }
  .pa-pdp__styling-cta-text { margin: 0; font-size: 13px; line-height: 1.5; color: #828282; }
  .pa-pdp__styling-cta-link { flex-shrink: 0; font-size: 12px; font-weight: 700; letter-spacing: 0.12em; color: #EF4B37; text-decoration: none; text-transform: uppercase; white-space: nowrap; }
  .pa-pdp__styling-cta-link:hover { opacity: 0.8; }
  @media (max-width: 749px) {
    .pa-pdp { padding: 0 0 48px; }
    .pa-pdp__layout { grid-template-columns: 1fr; gap: 24px; }
    .pa-pdp__media { position: static; }
    .pa-pdp__details { padding: 0 20px; }
    .pa-pdp__thumbs { padding: 0 20px; }
    .pa-pdp__styling-cta { flex-direction: column; align-items: flex-start; gap: 12px; }
  }
  @media (min-width: 750px) and (max-width: 989px) {
    .pa-pdp { padding: 24px 32px 48px; }
    .pa-pdp__layout { gap: 36px; }
  }
</style>

{% schema %}
{
  "name": "PA Product Page",
  "tag": "section",
  "settings": [
    { "type": "url", "id": "size_guide_url", "label": "Size Guide URL" },
    { "type": "url", "id": "styling_url", "label": "Styling Session URL" },
    { "type": "header", "content": "Trust Badges" },
    { "type": "text", "id": "badge_1_title", "label": "Badge 1 Title", "default": "FREE DELIVERY" },
    { "type": "text", "id": "badge_1_desc", "label": "Badge 1 Description", "default": "Over AED 400" },
    { "type": "text", "id": "badge_2_title", "label": "Badge 2 Title", "default": "AUTHENTICATED" },
    { "type": "text", "id": "badge_2_desc", "label": "Badge 2 Description", "default": "100% Verified" },
    { "type": "text", "id": "badge_3_title", "label": "Badge 3 Title", "default": "EASY RETURNS" },
    { "type": "text", "id": "badge_3_desc", "label": "Badge 3 Description", "default": "30-day policy" },
    { "type": "header", "content": "Accordion Content" },
    { "type": "textarea", "id": "delivery_text", "label": "Delivery & Returns Text", "default": "Complimentary standard delivery on orders over AED 400. Express same-day delivery available in Dubai for AED 85. Return any unworn item within 30 days of delivery." },
    { "type": "textarea", "id": "styling_text", "label": "Styling Session Text", "default": "Book a complimentary personal styling session with one of our expert stylists. In-store or virtual appointments available." },
    { "type": "textarea", "id": "default_description", "label": "Default Description (if product has none)" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" }
  ],
  "presets": [{ "name": "PA Product Page" }]
}
{% endschema %}