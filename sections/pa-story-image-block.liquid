<div class="section-background color-{{ section.settings.color_scheme }}"></div>

<div
  class="section section--page-width color-{{ section.settings.color_scheme }} pa-story-img-section spacing-style"
  style="{% render 'spacing-style', settings: section.settings %}"
>
  <div class="pa-story-img-block{% if section.settings.image_position == 'right' %} pa-story-img-block--reversed{% endif %}{% if section.settings.show_background %} pa-story-img-block--bg{% endif %}">
    <div class="pa-story-img-block__image-col">
      {%- if section.settings.image != blank -%}
        <img
          src="{{ section.settings.image | image_url: width: 1200 }}"
          alt="{{ section.settings.heading | escape }}"
          class="pa-story-img-block__image"
          loading="lazy"
          width="1200"
        >
      {%- else -%}
        {{ 'lifestyle-1' | placeholder_svg_tag: 'pa-story-img-block__image pa-story-img-block__image--placeholder' }}
      {%- endif -%}
    </div>

    <div class="pa-story-img-block__content-col">
      {%- if section.settings.label != blank -%}
        <p class="pa-story-img-block__label">{{ section.settings.label }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="pa-story-img-block__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- for block in section.blocks -%}
        {%- if block.settings.paragraph != blank -%}
          <p class="pa-story-img-block__paragraph" {{ block.shopify_attributes }}>{{ block.settings.paragraph }}</p>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</div>

<style>
  .pa-story-img-section {
    padding-block: 0 !important;
  }

  .pa-story-img-block {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 72px;
    align-items: center;
    padding: 52px;
    border-radius: 12px;
  }

  .pa-story-img-block--bg {
    background: #FAF9F7;
  }

  .pa-story-img-block--reversed {
    direction: rtl;
  }

  .pa-story-img-block--reversed > * {
    direction: ltr;
  }

  .pa-story-img-block__image {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 10px;
    object-fit: cover;
    aspect-ratio: 4 / 5;
  }

  .pa-story-img-block__image--placeholder {
    width: 100%;
    aspect-ratio: 4 / 5;
    border-radius: 10px;
  }

  .pa-story-img-block__content-col {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .pa-story-img-block__label {
    margin: 0;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #EF4B37;
  }

  .pa-story-img-block__heading {
    margin: 0;
    font-size: clamp(28px, 3vw, 44px);
    font-weight: 400;
    line-height: 1.1;
    color: var(--color-foreground);
    border: none;
    text-decoration: none;
  }

  .pa-story-img-block__paragraph {
    margin: 0;
    font-size: 15px;
    line-height: 1.7;
    color: #828282;
  }

  @media (max-width: 749px) {
    .pa-story-img-block {
      grid-template-columns: 1fr;
      gap: 28px;
      padding: 28px 20px;
      direction: ltr;
    }

    .pa-story-img-block--reversed > * {
      direction: ltr;
    }
  }
</style>

{% schema %}
{
  "name": "PA Story Image Block",
  "tag": "section",
  "max_blocks": 4,
  "blocks": [
    {
      "type": "paragraph",
      "name": "Paragraph",
      "settings": [
        { "type": "textarea", "id": "paragraph", "label": "Paragraph", "default": "Add your story paragraph here." }
      ]
    }
  ],
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image" },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image position",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    { "type": "checkbox", "id": "show_background", "label": "Show background (#FAF9F7)", "default": true },
    { "type": "text", "id": "label", "label": "Label", "default": "AFRICA" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Where It All Began .." },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "header", "content": "Padding" },
    { "type": "range", "id": "padding-block-start", "label": "Top", "min": 0, "max": 100, "step": 4, "unit": "px", "default": 48 },
    { "type": "range", "id": "padding-block-end", "label": "Bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "default": 48 }
  ],
  "presets": [
    {
      "name": "PA Story Image Block",
      "blocks": [
        { "type": "paragraph", "settings": { "paragraph": "Our roots run deep in the African soil. Polo was built on the belief that luxury should be accessible, authentic, and anchored in culture." } },
        { "type": "paragraph", "settings": { "paragraph": "That founding philosophy — of curating the extraordinary from every corner of the world — is what we carry into every collection, every boutique, every client relationship." } }
      ]
    }
  ]
}
{% endschema %}
