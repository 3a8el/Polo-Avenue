{% comment %}
  POLO AVENUE — The Houses We Carry (Designers Grid)
  Section: pa-designers.liquid
{% endcomment %}

<section class="pa-designers">
  <div class="pa-designers__header">
    <div>
      <p class="pa-label">{{ section.settings.label }}</p>
      <h2 class="pa-section-heading">{{ section.settings.heading }}</h2>
    </div>
    {%- if section.settings.all_url != blank -%}
      <a href="{{ section.settings.all_url }}" class="pa-explore-all">
        EXPLORE ALL
      </a>
    {%- endif -%}
  </div>

  <div class="pa-designers__grid">
    {%- for block in section.blocks -%}
      <div class="pa-designer-card" {{ block.shopify_attributes }}>
        <div style="position:relative; width:100%; height:100%;">
          {%- if block.settings.image != blank -%}
            <img
              class="pa-designer-card__image"
              src="{{ block.settings.image | image_url: width: 800 }}"
              alt="{{ block.settings.designer_name }}"
              loading="lazy"
            >
          {%- else -%}
            {{ 'collection-1' | placeholder_svg_tag: 'pa-designer-card__image' }}
          {%- endif -%}

          <div class="pa-designer-card__overlay"></div>

          <div class="pa-designer-card__info">
            {%- if block.settings.origin != blank or block.settings.since != blank -%}
              <p class="pa-designer-card__origin">
                {%- if block.settings.origin != blank -%}{{ block.settings.origin }}{%- endif -%}
                {%- if block.settings.origin != blank and block.settings.since != blank %} · {% endif -%}
                {%- if block.settings.since != blank -%}Since {{ block.settings.since }}{%- endif -%}
              </p>
            {%- endif -%}

            <div class="pa-designer-card__name-row">
              <h3 class="pa-designer-card__name">{{ block.settings.designer_name }}</h3>
              {%- if block.settings.collection_url != blank -%}
                <a href="{{ block.settings.collection_url }}" class="pa-designer-card__link">
                  VIEW COLLECTION
                </a>
              {%- endif -%}
            </div>
          </div>
        </div>
      </div>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "PA Designers",
  "tag": "section",
  "max_blocks": 9,
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Eyebrow Label",
      "default": "DESIGNERS"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Houses We Carry"
    },
    {
      "type": "url",
      "id": "all_url",
      "label": "Explore All URL"
    }
  ],
  "blocks": [
    {
      "type": "designer",
      "name": "Designer",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Designer Image"
        },
        {
          "type": "text",
          "id": "designer_name",
          "label": "Designer Name",
          "default": "GUCCI"
        },
        {
          "type": "text",
          "id": "origin",
          "label": "Country of Origin",
          "default": "Italy"
        },
        {
          "type": "text",
          "id": "since",
          "label": "Founded Year",
          "default": "1921"
        },
        {
          "type": "url",
          "id": "collection_url",
          "label": "Collection URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "PA Designers",
      "blocks": [
        { "type": "designer", "settings": { "designer_name": "GUCCI", "origin": "Italy", "since": "1921" } },
        { "type": "designer", "settings": { "designer_name": "VALENTINO", "origin": "Italy", "since": "1960" } },
        { "type": "designer", "settings": { "designer_name": "BALMAIN", "origin": "France", "since": "1945" } }
      ]
    }
  ]
}
{% endschema %}
