<div class="section-background color-{{ section.settings.color_scheme }}"></div>

<div
  class="section section--page-width color-{{ section.settings.color_scheme }} pa-cat spacing-style"
  style="{% render 'spacing-style', settings: section.settings %}"
>

  <div class="pa-cat__header">
    <div class="pa-cat__header-left">
      {%- if section.settings.label != blank -%}
        <p class="pa-cat__label">{{ section.settings.label }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="pa-cat__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
    </div>
    {%- if section.settings.cta_label != blank and section.settings.cta_url != blank -%}
      <a href="{{ section.settings.cta_url }}" class="pa-cat__cta">
        {{ section.settings.cta_label }}
        <svg width="9" height="8" viewBox="0 0 7 6" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M4.33333 0L6.33333 2.98611L4.33333 6H2.80556L4.27778 3.625H0V2.36111H4.27778L2.80556 0H4.33333Z" fill="#EF4B37"/>
        </svg>
      </a>
    {%- endif -%}
  </div>

  <div class="pa-cat__grid" id="pa-cat-grid-{{ section.id }}">
    {%- for block in section.blocks -%}
      <a
        href="{{ block.settings.url | default: '#' }}"
        class="pa-cat__card"
        {{ block.shopify_attributes }}
      >
        <div class="pa-cat__img-wrap">
          {%- if block.settings.image != blank -%}
            <img
              src="{{ block.settings.image | image_url: width: 900 }}"
              alt="{{ block.settings.name | escape }}"
              class="pa-cat__img"
              loading="{{ forloop.first | ternary: 'eager', 'lazy' }}"
              width="900"
            >
          {%- else -%}
            {{ 'lifestyle-1' | placeholder_svg_tag: 'pa-cat__img pa-cat__img--placeholder' }}
          {%- endif -%}
        </div>
        <div class="pa-cat__name-bar">
          <span class="pa-cat__name">{{ block.settings.name }}</span>
        </div>
      </a>
    {%- endfor -%}
  </div>

</div>

<style>
  /* ── Wrapper ── */
  .pa-cat {
    display: flex;
    flex-direction: column;
  }

  /* ── Header ── */
  .pa-cat__header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    padding: 0 0 20px;
    gap: 16px;
  }

  .pa-cat__header-left {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .pa-cat__label {
    margin: 0;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #EF4B37;
  }

  .pa-cat__heading {
    margin: 0;
    font-size: clamp(24px, 3vw, 40px);
    font-weight: 400;
    line-height: 1.1;
    color: var(--color-foreground);
    text-decoration: none !important;
    border-bottom: none !important;
  }

  .pa-cat__cta {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: #EF4B37;
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
    padding-bottom: 4px;
  }

  .pa-cat__cta:hover { opacity: 0.75; }

  /* ── Grid ── */
  .pa-cat__grid {
    display: flex;
    overflow-x: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .pa-cat__grid::-webkit-scrollbar { display: none; }

  /* ── Card ── */
  .pa-cat__card {
    flex: 1 0 calc(100% / 3);
    position: relative;
    overflow: hidden;
    display: block;
    text-decoration: none;
    height: {{ section.settings.card_height }}px;
  }

  .pa-cat__img-wrap {
    width: 100%;
    height: 100%;
  }

  .pa-cat__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
    transition: transform 0.5s ease;
  }

  .pa-cat__img--placeholder {
    width: 100%;
    height: 100%;
  }

  /* ── Name bar ── */
  .pa-cat__name-bar {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: #FAF9F7;
    padding: 14px 20px;
    text-align: center;
    transform: translateY(100%);
    transition: transform 0.3s ease;
  }

  .pa-cat__name {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #EF4B37;
  }

  /* ── Desktop hover ── */
  @media (min-width: 750px) {
    .pa-cat__card:hover .pa-cat__name-bar {
      transform: translateY(0);
    }

    .pa-cat__card:hover .pa-cat__img {
      transform: scale(1.03);
    }
  }

  /* ── Mobile ── */
  @media (max-width: 749px) {
    .pa-cat__grid {
      scroll-snap-type: x mandatory;
      gap: 0;
    }

    .pa-cat__card {
      flex: 0 0 88vw;
      height: {{ section.settings.card_height_mobile }}px;
      scroll-snap-align: start;
    }

    /* Name always visible on mobile */
    .pa-cat__name-bar {
      transform: translateY(0);
    }
  }
</style>

{% schema %}
{
  "name": "PA Category Showcase",
  "tag": "section",
  "max_blocks": 12,
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Category Name",
          "default": "DRESSES"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Link"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "CATEGORIES"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop By"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA Label",
      "default": "EXPLORE ALL"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA Link"
    },
    {
      "type": "range",
      "id": "card_height",
      "label": "Card height (desktop)",
      "min": 300,
      "max": 800,
      "step": 20,
      "unit": "px",
      "default": 520
    },
    {
      "type": "range",
      "id": "card_height_mobile",
      "label": "Card height (mobile)",
      "min": 300,
      "max": 700,
      "step": 20,
      "unit": "px",
      "default": 480
    },
    {
      "type": "header",
      "content": "Color"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "PA Category Showcase",
      "blocks": [
        { "type": "category", "settings": { "name": "DRESSES" } },
        { "type": "category", "settings": { "name": "SUITS" } },
        { "type": "category", "settings": { "name": "ACCESSORIES" } }
      ]
    }
  ]
}
{% endschema %}
