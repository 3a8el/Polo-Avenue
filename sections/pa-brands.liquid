<div class="pa-brands">
  <div class="pa-brands__track">
    {%- for block in section.blocks -%}
      {%- assign tag = 'span' -%}
      {%- if block.settings.link != blank -%}{%- assign tag = 'a' -%}{%- endif -%}
      <{{ tag }}
        class="pa-brands__item"
        {% if block.settings.link != blank %}href="{{ block.settings.link }}"{% endif %}
        {{ block.shopify_attributes }}
      >
        {%- if block.settings.logo != blank -%}
          <img
            src="{{ block.settings.logo | image_url: width: 160 }}"
            alt="{{ block.settings.brand_name }}"
            class="pa-brands__logo"
            width="160"
            height="60"
            loading="lazy"
          >
        {%- else -%}
          {{ block.settings.brand_name }}
        {%- endif -%}
      </{{ tag }}>
    {%- endfor -%}
    {%- comment %} Duplicate for seamless infinite scroll {%- endcomment %}
    {%- for block in section.blocks -%}
      {%- assign tag = 'span' -%}
      {%- if block.settings.link != blank -%}{%- assign tag = 'a' -%}{%- endif -%}
      <{{ tag }}
        class="pa-brands__item"
        {% if block.settings.link != blank %}href="{{ block.settings.link }}"{% endif %}
        aria-hidden="true"
        tabindex="-1"
      >
        {%- if block.settings.logo != blank -%}
          <img
            src="{{ block.settings.logo | image_url: width: 160 }}"
            alt="{{ block.settings.brand_name }}"
            class="pa-brands__logo"
            width="160"
            height="60"
            loading="lazy"
          >
        {%- else -%}
          {{ block.settings.brand_name }}
        {%- endif -%}
      </{{ tag }}>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "PA Brand Logos",
  "tag": "section",
  "max_blocks": 20,
  "blocks": [
    {
      "type": "brand",
      "name": "Brand",
      "settings": [
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Brand Logo"
        },
        {
          "type": "text",
          "id": "brand_name",
          "label": "Brand Name (fallback if no logo)",
          "default": "BRAND NAME"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Brand Archive Page Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "PA Brand Logos"
    }
  ]
}
{% endschema %}
