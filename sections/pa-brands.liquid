<div class="pa-brands">
  <div class="pa-brands__track">
    {%- for block in section.blocks -%}
      <span class="pa-brands__item" {{ block.shopify_attributes }}>
        {%- if block.settings.logo != blank -%}
          <img
            src="{{ block.settings.logo | image_url: width: 160 }}"
            alt="{{ block.settings.brand_name }}"
            class="pa-brands__logo"
            width="160"
            height="60"
            loading="lazy"
          >
        {%- else -%}
          {{ block.settings.brand_name }}
        {%- endif -%}
      </span>
    {%- endfor -%}
    {%- comment %} Duplicate for seamless infinite scroll {%- endcomment %}
    {%- for block in section.blocks -%}
      <span class="pa-brands__item" aria-hidden="true">
        {%- if block.settings.logo != blank -%}
          <img
            src="{{ block.settings.logo | image_url: width: 160 }}"
            alt="{{ block.settings.brand_name }}"
            class="pa-brands__logo"
            width="160"
            height="60"
            loading="lazy"
          >
        {%- else -%}
          {{ block.settings.brand_name }}
        {%- endif -%}
      </span>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "PA Brand Logos",
  "tag": "section",
  "max_blocks": 20,
  "blocks": [
    {
      "type": "brand",
      "name": "Brand",
      "settings": [
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Brand Logo"
        },
        {
          "type": "text",
          "id": "brand_name",
          "label": "Brand Name (fallback if no logo)",
          "default": "BRAND NAME"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "PA Brand Logos"
    }
  ]
}
{% endschema %}
