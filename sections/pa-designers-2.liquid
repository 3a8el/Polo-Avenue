<div class="section-background color-{{ section.settings.color_scheme }}"></div>

<div
  class="
    section
    section--{{ section.settings.section_width }}
    color-{{ section.settings.color_scheme }}
    pa-designers
    spacing-style
  "
  style="{% render 'spacing-style', settings: section.settings %}"
>
  <div class="pa-designers__inner">
  <div class="pa-designers__header">
    <div class="pa-designers__header-text">
      {%- if section.settings.label != blank -%}
        <p class="pa-designers__label">{{ section.settings.label }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="pa-designers__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
    </div>
    {%- if section.settings.explore_label != blank and section.settings.explore_url != blank -%}
      <a href="{{ section.settings.explore_url }}" class="pa-designers__explore-link">
        {{ section.settings.explore_label }} &rarr;
      </a>
    {%- endif -%}
  </div>

  <div class="pa-designers__grid">
    {%- for block in section.blocks -%}
      <div class="pa-designers__card" {{ block.shopify_attributes }}>
        <div class="pa-designers__card-image-wrap">
          {%- if block.settings.image != blank -%}
            <img
              src="{{ block.settings.image | image_url: width: 900 }}"
              alt="{{ block.settings.designer_name | escape }}"
              class="pa-designers__card-image"
              loading="lazy"
              width="900"
              height="1100"
            >
          {%- else -%}
            {{ 'lifestyle-1' | placeholder_svg_tag: 'pa-designers__card-image pa-designers__card-image--placeholder' }}
          {%- endif -%}
        </div>

        <div class="pa-designers__card-info">
          <p class="pa-designers__card-meta">
            {{- block.settings.origin -}}
            {%- if block.settings.origin != blank and block.settings.since != blank %} &middot; {% endif -%}
            {%- if block.settings.since != blank %}Since {{ block.settings.since }}{%- endif -%}
          </p>
          <div class="pa-designers__card-bottom">
            <h4 class="pa-designers__card-name">{{ block.settings.designer_name }}</h4>
            {%- if block.settings.collection_url != blank -%}
              <a href="{{ block.settings.collection_url }}" class="pa-designers__card-link">
                {{ section.settings.card_cta_label | default: 'VIEW COLLECTION' }} &rarr;
              </a>
            {%- endif -%}
          </div>
        </div>
      </div>
    {%- endfor -%}
  </div>
  </div>
</div>

<style>
  .pa-designers__inner {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .pa-designers__header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 16px;
  }

  .pa-designers__label {
    margin: 0 0 6px;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent, var(--color-link));
  }

  .pa-designers__heading {
    margin: 0;
    font-size: clamp(24px, 3vw, 40px);
    font-weight: 400;
    line-height: 1.1;
    color: var(--color-foreground);
  }

  .pa-designers__explore-link {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent, var(--color-link));
    text-decoration: none;
    white-space: nowrap;
    padding-bottom: 4px;
    border-bottom: 1px solid currentColor;
    transition: opacity 0.2s ease;
  }

  .pa-designers__explore-link:hover {
    opacity: 0.7;
  }

  .pa-designers__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  .pa-designers__card {
    position: relative;
    border-radius: 12px;
    overflow: hidden;
    background: var(--color-background);
  }

  .pa-designers__card-image-wrap {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
  }

  .pa-designers__card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    transition: transform 0.5s ease;
  }

  .pa-designers__card:hover .pa-designers__card-image {
    transform: scale(1.04);
  }

  .pa-designers__card-image--placeholder {
    width: 100%;
    height: 100%;
  }

  .pa-designers__card-info {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 24px 20px;
    background: rgba(250, 249, 247, 1)
    {% comment %} backdrop-filter: blur(8px); {% endcomment %}
    {% comment %} -webkit-backdrop-filter: blur(8px); {% endcomment %}
  }

  .pa-designers__card-meta {
    margin: 0 0 6px;
    font-size: 10px;
    font-weight: 400;
    letter-spacing: 0.05em;
    color: #EF4B37;
  }

  .pa-designers__card-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
  }

  .pa-designers__card-name {
    margin: 0;
    font-size: 16px;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-foreground);
  }

  .pa-designers__card-link {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    {% comment %} color: var(--color-accent, var(--color-link)); {% endcomment %}
    color:#EF4B37;
    text-decoration: none;
    white-space: nowrap;
    transition: opacity 0.2s ease;
  }

  .pa-designers__card-link:hover {
    opacity: 0.7;
  }

  @media (max-width: 768px) {
    .pa-designers__grid {
      grid-template-columns: 1fr;
      gap: 12px;
    }

    .pa-designers__card-image-wrap {
      aspect-ratio: 4 / 3;
    }
  }
</style>

{% schema %}
{
  "name": "PA Designers",
  "tag": "section",
  "max_blocks": 12,
  "blocks": [
    {
      "type": "designer",
      "name": "Designer Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "designer_name",
          "label": "Designer Name",
          "default": "DESIGNER"
        },
        {
          "type": "text",
          "id": "origin",
          "label": "Country of Origin",
          "default": "Italy"
        },
        {
          "type": "text",
          "id": "since",
          "label": "Founded Year",
          "default": "1921"
        },
        {
          "type": "url",
          "id": "collection_url",
          "label": "Collection Link"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "DESIGNERS"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Houses We Carry"
    },
    {
      "type": "text",
      "id": "explore_label",
      "label": "Explore All Label",
      "default": "EXPLORE ALL"
    },
    {
      "type": "url",
      "id": "explore_url",
      "label": "Explore All Link"
    },
    {
      "type": "text",
      "id": "card_cta_label",
      "label": "Card CTA Label",
      "default": "VIEW COLLECTION"
    },
    {
      "type": "header",
      "content": "Section Layout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Width",
      "options": [
        { "value": "page-width", "label": "Page" },
        { "value": "full-width", "label": "Full" }
      ],
      "default": "page-width"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 48
    }
  ],
  "presets": [
    {
      "name": "PA Designers",
      "blocks": [
        {
          "type": "designer",
          "settings": {
            "designer_name": "GUCCI",
            "origin": "Italy",
            "since": "1921"
          }
        },
        {
          "type": "designer",
          "settings": {
            "designer_name": "VALENTINO",
            "origin": "Italy",
            "since": "1960"
          }
        },
        {
          "type": "designer",
          "settings": {
            "designer_name": "BALMAIN",
            "origin": "France",
            "since": "1945"
          }
        }
      ]
    }
  ]
}
{% endschema %}
