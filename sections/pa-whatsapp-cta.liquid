{% comment %}
  POLO AVENUE — WhatsApp CTA Section
  Section: pa-whatsapp-cta.liquid
{% endcomment %}

<section class="pa-whatsapp-cta">
  <div class="pa-whatsapp-cta__bg-text" aria-hidden="true">
    POLO AVENUE
  </div>

  <div class="pa-whatsapp-cta__inner">
    {%- if section.settings.label != blank -%}
      <p class="pa-label">{{ section.settings.label }}</p>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h2 class="pa-whatsapp-cta__title">{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- if section.settings.description != blank -%}
      <p class="pa-whatsapp-cta__desc">{{ section.settings.description }}</p>
    {%- endif -%}

    {%- if section.settings.whatsapp_number != blank -%}
      {%- assign wa_number = section.settings.whatsapp_number | remove: '+' | remove: ' ' | remove: '-' -%}
      {%- assign wa_message = section.settings.whatsapp_message | url_encode -%}
      <a
        href="https://wa.me/{{ wa_number }}?text={{ wa_message }}"
        target="_blank"
        rel="noopener noreferrer"
        class="pa-btn pa-btn--outline"
      >
        {{ section.settings.button_label | default: 'CHAT ON WHATSAPP' }}
      </a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "PA WhatsApp CTA",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Eyebrow Label",
      "default": "YOUR PERSONAL STYLIST AWAITS"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Book a Styling Session on WhatsApp"
    },
    {
      "type": "text",
      "id": "description",
      "label": "Description",
      "default": "Let our expert stylists curate a wardrobe uniquely yours."
    },
    {
      "type": "text",
      "id": "whatsapp_number",
      "label": "WhatsApp Number (with country code)",
      "default": "+971500000000",
      "info": "Include country code e.g. +971500000000"
    },
    {
      "type": "text",
      "id": "whatsapp_message",
      "label": "Pre-filled WhatsApp Message",
      "default": "Hello, I'd like to book a personal styling session."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "CHAT ON WHATSAPP"
    }
  ],
  "presets": [
    {
      "name": "PA WhatsApp CTA"
    }
  ]
}
{% endschema %}
