<div class="pa-ig-wrap color-{{ section.settings.color_scheme }}">

  {%- if section.settings.heading != blank -%}
    <h2 class="pa-instagram__heading">{{ section.settings.heading }}</h2>
  {%- endif -%}

  <div class="pa-instagram__stage">

    {%- comment %} Build 4 columns from blocks {%- endcomment %}
    {%- assign col_size = section.blocks.size | divided_by: 4 | at_least: 1 -%}

    <div class="pa-instagram__grid">
      {%- for col_index in (0..3) -%}
        <div class="pa-instagram__col{% if col_index == 1 or col_index == 3 %} pa-instagram__col--offset{% endif %}">
          <div class="pa-instagram__col-track">
            {%- comment %} First pass {%- endcomment %}
            {%- for block in section.blocks -%}
              {%- assign slot = forloop.index0 | modulo: 4 -%}
              {%- if slot == col_index -%}
                <div class="pa-instagram__post" {{ block.shopify_attributes }}>
                  {%- if block.settings.image != blank -%}
                    <img
                      src="{{ block.settings.image | image_url: width: 600 }}"
                      alt="{{ block.settings.alt | default: 'Instagram post' | escape }}"
                      loading="lazy"
                      width="600"
                    >
                  {%- else -%}
                    {{ 'lifestyle-1' | placeholder_svg_tag: 'pa-instagram__placeholder' }}
                  {%- endif -%}
                </div>
              {%- endif -%}
            {%- endfor -%}
            {%- comment %} Duplicate for seamless loop {%- endcomment %}
            {%- for block in section.blocks -%}
              {%- assign slot = forloop.index0 | modulo: 4 -%}
              {%- if slot == col_index -%}
                <div class="pa-instagram__post" aria-hidden="true">
                  {%- if block.settings.image != blank -%}
                    <img
                      src="{{ block.settings.image | image_url: width: 600 }}"
                      alt=""
                      loading="lazy"
                      width="600"
                    >
                  {%- else -%}
                    {{ 'lifestyle-1' | placeholder_svg_tag: 'pa-instagram__placeholder' }}
                  {%- endif -%}
                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>
      {%- endfor -%}
    </div>

    {%- comment %} Blur fade overlay from bottom to top {%- endcomment %}
    <div class="pa-instagram__blur-fade"></div>
    <div class="pa-instagram__gradient-fade"></div>

    {%- comment %} Center content {%- endcomment %}
    <div class="pa-instagram__content">
      {%- if section.settings.overlay_text != blank -%}
        <p class="pa-instagram__tagline">{{ section.settings.overlay_text }}</p>
      {%- endif -%}
      {%- if section.settings.follow_label != blank and section.settings.instagram_url != blank -%}
        <a
          href="{{ section.settings.instagram_url }}"
          class="pa-instagram__follow-btn"
          target="_blank"
          rel="noopener noreferrer"
        >
          {{ section.settings.follow_label }}
        </a>
      {%- endif -%}
    </div>

  </div>
</div>

<style>
  .pa-ig-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
    overflow: hidden;
  }

  .pa-instagram__heading {
    text-align: center;
    font-size: clamp(20px, 2.5vw, 32px);
    font-weight: 400;
    margin: 0;
    padding: 40px 24px 24px;
    color: var(--color-foreground);
    position: relative;
    z-index: 2;
  }

  /* ── Stage ── */
  .pa-instagram__stage {
    position: relative;
    width: 100vw;
    height: 560px;
    overflow: hidden;
  }

  /* ── Grid ── */
  .pa-instagram__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 8px;
    width: 100%;
    height: 100%;
    padding: 0 8px;
    box-sizing: border-box;
  }

  .pa-instagram__col {
    overflow: hidden;
    height: 100%;
  }

  /* ── Scrolling track ── */
  .pa-instagram__col-track {
    display: flex;
    flex-direction: column;
    gap: 8px;
    animation: pa-col-scroll 20s linear infinite;
  }

  .pa-instagram__col--offset .pa-instagram__col-track {
    margin-top: -100px;
    animation-duration: 25s;
    animation-direction: reverse;
  }

  @keyframes pa-col-scroll {
    from { transform: translateY(0); }
    to   { transform: translateY(-50%); }
  }

  .pa-instagram__post {
    border-radius: 8px;
    overflow: hidden;
    flex-shrink: 0;
  }

  .pa-instagram__post img,
  .pa-instagram__placeholder {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 8px;
  }

  /* ── Blur fade: bottom → top ── */
  .pa-instagram__blur-fade {
    position: absolute;
    inset: 0;
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    -webkit-mask-image: linear-gradient(to top, black 0%, black 45%, transparent 75%);
    mask-image: linear-gradient(to top, black 0%, black 45%, transparent 75%);
    pointer-events: none;
    z-index: 1;
  }

  .pa-instagram__gradient-fade {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(255, 255, 255, 0.75) 0%, rgba(255, 255, 255, 0.1) 50%, transparent 70%);
    pointer-events: none;
    z-index: 1;
  }

  /* ── Center overlay content ── */
  .pa-instagram__content {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
    padding-bottom: 48px;
    gap: 20px;
    z-index: 2;
  }

  .pa-instagram__tagline {
    margin: 0;
    font-size: clamp(18px, 2vw, 26px);
    font-weight: 400;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-foreground);
  }

  .pa-instagram__follow-btn {
    display: inline-block;
    padding: 12px 28px;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-foreground);
    background: var(--color-background);
    border: 1px solid var(--color-foreground);
    border-radius: 4px;
    text-decoration: none;
    transition: background 0.2s ease, color 0.2s ease;
  }

  .pa-instagram__follow-btn:hover {
    background: var(--color-foreground);
    color: var(--color-background);
  }

  /* ── Mobile: 2 columns ── */
  @media (max-width: 749px) {
    .pa-instagram__stage {
      height: 420px;
    }

    .pa-instagram__grid {
      grid-template-columns: repeat(2, 1fr) !important;
    }

    .pa-instagram__col:nth-child(n+3) {
      display: none !important;
    }
  }
</style>

{% schema %}
{
  "name": "PA Instagram",
  "tag": "section",
  "max_blocks": 16,
  "blocks": [
    {
      "type": "post",
      "name": "Post",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "alt",
          "label": "Alt text"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Follow us on Instagram"
    },
    {
      "type": "text",
      "id": "overlay_text",
      "label": "Overlay Text",
      "default": "AUTHENTICALLY AFRICAN."
    },
    {
      "type": "text",
      "id": "follow_label",
      "label": "Button Label",
      "default": "FOLLOW POLO AVENUE"
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "Instagram URL"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ],
  "presets": [
    {
      "name": "PA Instagram",
      "blocks": [
        { "type": "post" },
        { "type": "post" },
        { "type": "post" },
        { "type": "post" },
        { "type": "post" },
        { "type": "post" },
        { "type": "post" },
        { "type": "post" }
      ]
    }
  ]
}
{% endschema %}
