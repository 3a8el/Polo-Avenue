<div class="section-background color-{{ section.settings.color_scheme }}"></div>

<div
  class="section section--full-width color-{{ section.settings.color_scheme }} pa-shipping-cards spacing-style"
  style="{% render 'spacing-style', settings: section.settings %}"
>
  <div class="pa-shipping-cards__inner">

    <div class="pa-shipping-cards__header">
      {%- if section.settings.label != blank -%}
        <p class="pa-shipping-cards__label">{{ section.settings.label }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h1 class="pa-shipping-cards__heading">{{ section.settings.heading }}</h1>
      {%- endif -%}
    </div>

    <div class="pa-shipping-cards__grid">
      {%- for block in section.blocks -%}
        <div class="pa-shipping-cards__card" {{ block.shopify_attributes }}>
          <span class="pa-shipping-cards__card-icon" aria-hidden="true">
            {{- 'pa-star.svg' | inline_asset_content -}}
          </span>
          {%- if block.settings.title != blank -%}
            <h3 class="pa-shipping-cards__card-title">{{ block.settings.title }}</h3>
          {%- endif -%}
          {%- if block.settings.description != blank -%}
            <p class="pa-shipping-cards__card-desc">{{ block.settings.description }}</p>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>

  </div>
</div>

<style>
  .pa-shipping-cards__inner {
    display: flex;
    flex-direction: column;
    gap: 40px;
    padding-inline: 60px;
  }

  /* ── Header ── */
  .pa-shipping-cards__header {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .pa-shipping-cards__label {
    margin: 0;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #EF4B37;
  }

  .pa-shipping-cards__heading {
    margin: 0;
    font-size: clamp(28px, 4vw, 48px);
    font-weight: 400;
    line-height: 1.1;
    color: var(--color-foreground);
    border: none;
    text-decoration: none;
  }

  /* ── Grid ── */
  .pa-shipping-cards__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 28px;
  }

  /* ── Card ── */
  .pa-shipping-cards__card {
    display: flex;
    flex-direction: column;
    gap: 0;
    background: #FAF9F7;
    border-top: 2px solid #EF4B37;
    border-radius: 0 0 8px 8px;
    padding: 20px 20px 80px;
  }

  .pa-shipping-cards__card-icon {
    display: flex;
    align-items: center;
    margin-bottom: 8px;
    flex-shrink: 0;
  }

  .pa-shipping-cards__card-icon svg {
    width: 16px;
    height: 16px;
    display: block;
  }

  .pa-shipping-cards__card-title {
    margin: 0 0 4px;
    font-family: 'Montserrat', var(--font-body--family), sans-serif;
    font-size: 16px;
    font-weight: 600;
    line-height: 1.3;
    color: #1A1A1A;
  }

  .pa-shipping-cards__card-desc {
    margin: 0;
    font-size: 14px;
    font-weight: 400;
    line-height: 1.6;
    letter-spacing: 0.004em;
    color: #828282;
  }

  /* ── Tablet ── */
  @media (max-width: 989px) {
    .pa-shipping-cards__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 20px;
    }
  }

  /* ── Mobile ── */
  @media (max-width: 749px) {
    .pa-shipping-cards__inner {
      padding-inline: 24px;
      gap: 28px;
    }

    .pa-shipping-cards__grid {
      grid-template-columns: 1fr;
      gap: 16px;
    }

    .pa-shipping-cards__card {
      padding-bottom: 48px;
    }
  }
</style>

{% schema %}
{
  "name": "PA Shipping Cards",
  "tag": "section",
  "max_blocks": 8,
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Card Title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "A short description for this card."
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "SHIPPING & RETURNS"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Customer Care"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "PA Shipping Cards",
      "blocks": [
        {
          "type": "card",
          "settings": {
            "title": "Free Delivery",
            "description": "Complimentary standard delivery on all orders over AED 400. Express same-day delivery available in Dubai for AED 85."
          }
        },
        {
          "type": "card",
          "settings": {
            "title": "Easy Returns",
            "description": "Return any unworn item within 30 days of delivery. Items must have original tags attached and be in original packaging."
          }
        },
        {
          "type": "card",
          "settings": {
            "title": "Authentication",
            "description": "Every item is guaranteed authentic. We provide a Certificate of Authenticity for all fine jewellery and select luxury items."
          }
        },
        {
          "type": "card",
          "settings": {
            "title": "Gift Returns",
            "description": "Gift recipients may return items within 30 days with proof of purchase. Exchange or store credit issued."
          }
        }
      ]
    }
  ]
}
{% endschema %}
