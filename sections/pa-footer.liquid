{% comment %}
  POLO AVENUE — Footer
  Section: pa-footer.liquid
{% endcomment %}

<footer class="pa-footer">
  <div class="pa-footer__main">

    <!-- Brand Column -->
    <div class="pa-footer__brand">
      <a href="/" class="pa-footer__logo">
        {%- if section.settings.logo != blank -%}
          <img
            src="{{ section.settings.logo | image_url: width: 200 }}"
            alt="{{ shop.name }}"
          >
        {%- else -%}
          <span style="font-family: var(--font-heading); font-size: 22px; letter-spacing: 0.05em;">
            {{ shop.name }}
          </span>
        {%- endif -%}
      </a>

      <div class="pa-footer__address-block">
        {%- if section.settings.address != blank -%}
          <p>{{ section.settings.address }}</p>
        {%- endif -%}
        {%- if section.settings.email != blank -%}
          <p><a href="mailto:{{ section.settings.email }}">{{ section.settings.email }}</a></p>
        {%- endif -%}
        {%- if section.settings.hours != blank -%}
          <p>{{ section.settings.hours }}</p>
        {%- endif -%}
      </div>

      <div class="pa-footer__socials">
        {%- if section.settings.instagram_url != blank -%}
          <a href="{{ section.settings.instagram_url }}" class="pa-footer__social-link" target="_blank" rel="noopener" aria-label="Instagram">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
            </svg>
          </a>
        {%- endif -%}

        {%- if section.settings.tiktok_url != blank -%}
          <a href="{{ section.settings.tiktok_url }}" class="pa-footer__social-link" target="_blank" rel="noopener" aria-label="TikTok">
            <svg viewBox="0 0 24 24" fill="currentColor">
              <path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.18 8.18 0 004.78 1.52V6.76a4.85 4.85 0 01-1.01-.07z"/>
            </svg>
          </a>
        {%- endif -%}

        {%- if section.settings.facebook_url != blank -%}
          <a href="{{ section.settings.facebook_url }}" class="pa-footer__social-link" target="_blank" rel="noopener" aria-label="Facebook">
            <svg viewBox="0 0 24 24" fill="currentColor">
              <path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/>
            </svg>
          </a>
        {%- endif -%}
      </div>
    </div>

    <!-- Shop Column -->
    <div class="pa-footer__col">
      <h4 class="pa-footer__col-heading">SHOP</h4>
      <ul class="pa-footer__links">
        <li><a href="{{ routes.collections_url }}/new-arrivals">New Arrivals</a></li>
        <li><a href="{{ routes.collections_url }}">Collections</a></li>
        <li><a href="/pages/designers">Designers</a></li>
        <li><a href="/pages/gift-services">Gift Services</a></li>
      </ul>
    </div>

    <!-- Discover Column -->
    <div class="pa-footer__col">
      <h4 class="pa-footer__col-heading">DISCOVER</h4>
      <ul class="pa-footer__links">
        <li><a href="/pages/about">About Us</a></li>
        <li><a href="/pages/boutique-locator">Boutique Locator</a></li>
        <li><a href="/pages/personal-styling">Personal Styling</a></li>
        <li><a href="/pages/shipping-returns">Shipping & Returns</a></li>
      </ul>
    </div>

    <!-- Account Column -->
    <div class="pa-footer__col">
      <h4 class="pa-footer__col-heading">ACCOUNT</h4>
      <ul class="pa-footer__links">
        <li><a href="{{ routes.account_login_url }}">Sign In</a></li>
        <li><a href="/pages/wishlist">Wishlist</a></li>
        <li><a href="{{ routes.account_url }}/orders">My Orders</a></li>
      </ul>
    </div>

  </div>

  <div class="pa-footer__bottom">
    <p class="pa-footer__copyright">
      &copy; {{ 'now' | date: '%Y' }} {{ section.settings.copyright_name | default: shop.name }}. All Rights Reserved.
    </p>
    <div class="pa-footer__legal">
      <a href="/policies/privacy-policy">Privacy Policy</a>
      <a href="/policies/terms-of-service">Terms & Conditions</a>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "PA Footer",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Brand"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Footer Logo"
    },
    {
      "type": "text",
      "id": "copyright_name",
      "label": "Copyright Name",
      "default": "Polo Avenue Dubai"
    },
    {
      "type": "header",
      "content": "Contact"
    },
    {
      "type": "text",
      "id": "address",
      "label": "Address",
      "default": "Jumeirah Boutique, Dubai, UAE"
    },
    {
      "type": "text",
      "id": "email",
      "label": "Email",
      "default": "concierge@poloavenue.ae"
    },
    {
      "type": "text",
      "id": "hours",
      "label": "Opening Hours",
      "default": "Mon–Sat: 10am–8pm | Sun: 12pm–6pm"
    },
    {
      "type": "header",
      "content": "Social Links"
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "tiktok_url",
      "label": "TikTok URL"
    },
    {
      "type": "url",
      "id": "facebook_url",
      "label": "Facebook URL"
    }
  ],
  "presets": [
    {
      "name": "PA Footer"
    }
  ]
}
{% endschema %}
