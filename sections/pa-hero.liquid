{% comment %}
  POLO AVENUE — Hero Section
  Section: pa-hero.liquid
{% endcomment %}

<section class="pa-hero">
  {%- if section.settings.image != blank -%}
    <img
      class="pa-hero__image"
      src="{{ section.settings.image | image_url: width: 2400 }}"
      alt="{{ section.settings.image.alt | escape }}"
      loading="eager"
      fetchpriority="high"
    >
  {%- else -%}
    {{ 'lifestyle-1' | placeholder_svg_tag: 'pa-hero__image' }}
  {%- endif -%}

  <div class="pa-hero__overlay"></div>

  <div class="pa-hero__content">
    {%- if section.settings.title != blank -%}
      <h1 class="pa-hero__title">{{ section.settings.title }}</h1>
    {%- endif -%}

    {%- if section.settings.subtitle != blank -%}
      <p class="pa-hero__subtitle">{{ section.settings.subtitle }}</p>
    {%- endif -%}

    <div class="pa-hero__actions">
      {%- if section.settings.button_1_label != blank -%}
        <a href="{{ section.settings.button_1_url }}" class="pa-btn pa-btn--solid">
          {{ section.settings.button_1_label }}
        </a>
      {%- endif -%}

      {%- if section.settings.button_2_label != blank -%}
        <a href="{{ section.settings.button_2_url }}" class="pa-btn pa-btn--outline" style="color:white;border-color:rgba(255,255,255,0.7);">
          {{ section.settings.button_2_label }}
        </a>
      {%- endif -%}
    </div>
  </div>

  {%- if section.settings.tagline != blank -%}
    <p class="pa-hero__tagline">{{ section.settings.tagline }}</p>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "PA Hero",
  "tag": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero Image"
    },
    {
      "type": "richtext",
      "id": "title",
      "label": "Heading",
      "default": "<p>LUXURY, <em>CURATED</em>.<br>AUTHENTICALLY AFRICAN.</p>"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Polo Avenue brings the soul of African luxury to Dubai's Jumeirah."
    },
    {
      "type": "text",
      "id": "button_1_label",
      "label": "Button 1 Label",
      "default": "SHOP NEW ARRIVALS"
    },
    {
      "type": "url",
      "id": "button_1_url",
      "label": "Button 1 URL"
    },
    {
      "type": "text",
      "id": "button_2_label",
      "label": "Button 2 Label",
      "default": "SHOP THE EDIT"
    },
    {
      "type": "url",
      "id": "button_2_url",
      "label": "Button 2 URL"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Bottom Tagline",
      "default": "Dubai's foremost destination for authenticated global luxury — curated from Africa's finest fashion houses."
    }
  ],
  "presets": [
    {
      "name": "PA Hero"
    }
  ]
}
{% endschema %}
