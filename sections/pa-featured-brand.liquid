{% comment %}
  POLO AVENUE — Featured Brand Banner
  Section: pa-featured-brand.liquid
{% endcomment %}

<section class="pa-featured-brand">
  {%- if section.settings.image != blank -%}
    <img
      class="pa-featured-brand__image"
      src="{{ section.settings.image | image_url: width: 2400 }}"
      alt="{{ section.settings.image.alt | escape | default: section.settings.brand_name }}"
      loading="lazy"
    >
  {%- else -%}
    {{ 'lifestyle-2' | placeholder_svg_tag: 'pa-featured-brand__image' }}
  {%- endif -%}

  <div class="pa-featured-brand__overlay"></div>

  {%- if section.settings.brand_name != blank -%}
    <h2 class="pa-featured-brand__name">{{ section.settings.brand_name }}</h2>
  {%- endif -%}

  {%- if section.settings.button_label != blank -%}
    <div class="pa-featured-brand__cta">
      <a href="{{ section.settings.button_url }}" class="pa-btn pa-btn--solid">
        {{ section.settings.button_label }}
      </a>
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "PA Featured Brand",
  "tag": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Brand Image"
    },
    {
      "type": "text",
      "id": "brand_name",
      "label": "Brand Name",
      "default": "TORLOWEI"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "EXPLORE THE COLLECTION"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button URL"
    }
  ],
  "presets": [
    {
      "name": "PA Featured Brand"
    }
  ]
}
{% endschema %}
