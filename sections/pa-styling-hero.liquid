<div class="section-background color-{{ section.settings.color_scheme }}"></div>

<div class="pa-styling-hero">
  {%- if section.settings.image != blank -%}
    <img
      class="pa-styling-hero__image"
      src="{{ section.settings.image | image_url: width: 2400 }}"
      alt="{{ section.settings.image.alt | escape }}"
      loading="eager"
      fetchpriority="high"
      width="2400"
    >
  {%- else -%}
    {{ 'lifestyle-1' | placeholder_svg_tag: 'pa-styling-hero__image pa-styling-hero__image--placeholder' }}
  {%- endif -%}

  <div class="pa-styling-hero__overlay"></div>

  <div class="pa-styling-hero__content">
    {%- if section.settings.label != blank -%}
      <p class="pa-styling-hero__label">{{ section.settings.label }}</p>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h1 class="pa-styling-hero__heading">{{ section.settings.heading }}</h1>
    {%- endif -%}
    {%- if section.settings.subheading != blank -%}
      <p class="pa-styling-hero__subheading">{{ section.settings.subheading }}</p>
    {%- endif -%}
    {%- if section.settings.button_label != blank -%}
      <a
        href="{{ section.settings.button_url }}"
        class="pa-styling-hero__btn"
      >
        {{ section.settings.button_label }}
      </a>
    {%- endif -%}
  </div>
</div>

<style>
  .pa-styling-hero {
    position: relative;
    width: 100%;
    height: 60vh;
    min-height: 420px;
    overflow: hidden;
  }

  .pa-styling-hero__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .pa-styling-hero__image--placeholder {
    width: 100%;
    height: 100%;
  }

  .pa-styling-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      rgba(0, 0, 0, 0.6) 0%,
      rgba(0, 0, 0, 0.2) 60%,
      transparent 100%
    );
  }

  .pa-styling-hero__content {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 0 var(--page-margin, 60px) 60px;
    max-width: 772px;
    gap: 16px;
  }

  .pa-styling-hero__label {
    margin: 0;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #EF4B37;
  }

  .pa-styling-hero__heading {
    margin: 0;
    font-size: clamp(32px, 5vw, 64px);
    font-weight: 400;
    line-height: 1.05;
    color: #ffffff;
    letter-spacing: -0.01em;
    border: none;
    text-decoration: none;
  }

  .pa-styling-hero__subheading {
    margin: 0;
    font-size: 15px;
    font-weight: 300;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.85);
    max-width: 480px;
  }

  .pa-styling-hero__btn {
    display: inline-block;
    width: fit-content;
    padding: 14px 28px;
    margin-top: 8px;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #1a1a1a;
    background: #ffffff;
    border: 1.5px solid #ffffff;
    border-radius: 4px;
    text-decoration: none;
    transition: background 0.2s ease, color 0.2s ease;
  }

  .pa-styling-hero__btn:hover {
    background: transparent;
    color: #ffffff;
  }

  @media (max-width: 749px) {
    .pa-styling-hero {
      height: 70vmax;
      min-height: 360px;
    }

    .pa-styling-hero__content {
      padding: 0 24px 40px;
      max-width: 100%;
    }

    .pa-styling-hero__overlay {
      background: rgba(0, 0, 0, 0.45);
    }
  }
</style>

{% schema %}
{
  "name": "PA Styling Hero",
  "tag": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background Image"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "PERSONAL STYLING"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Your Style, Perfectly Curated."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Our team of expert stylists is dedicated to understanding your taste, lifestyle, and wardrobe aspirations. Every session is confidential, personalized, and entirely at your service."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "BOOK A STYLING SESSION"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button URL"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ],
  "presets": [
    {
      "name": "PA Styling Hero"
    }
  ]
}
{% endschema %}
