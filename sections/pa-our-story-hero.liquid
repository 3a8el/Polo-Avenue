<div class="section-background color-{{ section.settings.color_scheme }}"></div>

<div class="pa-os-hero">
  {%- if section.settings.image != blank -%}
    <img
      src="{{ section.settings.image | image_url: width: 2400 }}"
      alt="{{ section.settings.heading | escape }}"
      class="pa-os-hero__image"
      loading="eager"
      width="2400"
    >
  {%- else -%}
    {{ 'lifestyle-2' | placeholder_svg_tag: 'pa-os-hero__image pa-os-hero__image--placeholder' }}
  {%- endif -%}

  <div class="pa-os-hero__overlay"></div>

  <div class="pa-os-hero__inner">
    <div class="pa-os-hero__left">
      {%- if section.settings.label != blank -%}
        <p class="pa-os-hero__label">{{ section.settings.label }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h1 class="pa-os-hero__heading">{{ section.settings.heading }}</h1>
      {%- endif -%}
      {%- if section.settings.subtext != blank -%}
        <p class="pa-os-hero__subtext">{{ section.settings.subtext }}</p>
      {%- endif -%}
    </div>

    <div class="pa-os-hero__right">
      {%- if section.settings.stat_number != blank -%}
        <p class="pa-os-hero__stat-number">{{ section.settings.stat_number }}</p>
      {%- endif -%}
      <div class="pa-os-hero__stat-divider"></div>
      {%- if section.settings.stat_label != blank -%}
        <p class="pa-os-hero__stat-label">{{ section.settings.stat_label }}</p>
      {%- endif -%}
    </div>
  </div>
</div>

<style>
  .pa-os-hero {
    position: relative;
    width: 100%;
    min-height: 56vh;
    overflow: hidden;
    display: flex;
    align-items: flex-end;
  }

  .pa-os-hero__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
  }

  .pa-os-hero__image--placeholder {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .pa-os-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.72) 0%, rgba(0,0,0,0.3) 50%, rgba(0,0,0,0.15) 100%);
  }

  .pa-os-hero__inner {
    position: relative;
    z-index: 1;
    width: 100%;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    padding: 52px 60px;
    gap: 40px;
  }

  .pa-os-hero__left {
    display: flex;
    flex-direction: column;
    gap: 10px;
    flex: 1;
  }

  .pa-os-hero__label {
    margin: 0;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #EF4B37;
  }

  .pa-os-hero__heading {
    margin: 0;
    font-size: clamp(36px, 5vw, 64px);
    font-weight: 400;
    line-height: 1.05;
    color: #fff;
    border: none;
    text-decoration: none;
  }

  .pa-os-hero__subtext {
    margin: 0;
    font-size: 15px;
    line-height: 1.6;
    color: rgba(255,255,255,0.85);
    max-width: 420px;
  }

  .pa-os-hero__right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 8px;
    flex-shrink: 0;
  }

  .pa-os-hero__stat-number {
    margin: 0;
    font-size: 48px;
    font-weight: 300;
    line-height: 1;
    color: #828282;
    letter-spacing: -0.02em;
  }

  .pa-os-hero__stat-divider {
    width: 100%;
    height: 1px;
    background: #828282;
    opacity: 0.5;
  }

  .pa-os-hero__stat-label {
    margin: 0;
    font-size: 14px;
    font-weight: 400;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #828282;
  }

  @media (max-width: 749px) {
    .pa-os-hero__inner {
      flex-direction: column;
      align-items: flex-start;
      padding: 36px 24px;
      gap: 24px;
    }

    .pa-os-hero__right {
      align-items: flex-start;
    }
  }
</style>

{% schema %}
{
  "name": "PA Our Story Hero",
  "tag": "section",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Background Image" },
    { "type": "text", "id": "label", "label": "Label", "default": "HERITAGE" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Our Story" },
    { "type": "textarea", "id": "subtext", "label": "Subtext", "default": "Born in Africa. Arrived in Dubai.\nA legacy of luxury, carried across continents." },
    { "type": "text", "id": "stat_number", "label": "Stat Number", "default": "1994" },
    { "type": "text", "id": "stat_label", "label": "Stat Label", "default": "FOUNDED IN AFRICA" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" }
  ],
  "presets": [{ "name": "PA Our Story Hero" }]
}
{% endschema %}
