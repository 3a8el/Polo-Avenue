<div class="section-background color-{{ section.settings.color_scheme }}"></div>

<div
  class="
    section
    section--full-width
    color-{{ section.settings.color_scheme }}
    pa-boutique
    spacing-style
  "
  style="{% render 'spacing-style', settings: section.settings %}"
>
  <div class="pa-boutique__inner">

    {%- comment %} ── Left: Map ── {%- endcomment %}
    <div class="pa-boutique__map">
      {%- if section.settings.map_embed_url != blank -%}
        <iframe
          src="{{ section.settings.map_embed_url }}"
          width="100%"
          height="100%"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Store location map"
        ></iframe>
      {%- else -%}
        <div class="pa-boutique__map-placeholder">
          <p>Add a Google Maps embed URL in section settings</p>
        </div>
      {%- endif -%}
    </div>

    {%- comment %} ── Right: Info ── {%- endcomment %}
    <div class="pa-boutique__info">

      <div class="pa-boutique__brand">
        {%- if section.settings.logo != blank -%}
          <img
            src="{{ section.settings.logo | image_url: width: 240 }}"
            alt="{{ shop.name }}"
            class="pa-boutique__logo"
            width="180"
            loading="lazy"
          >
        {%- else -%}
          <span class="pa-boutique__shop-name">{{ shop.name }}</span>
        {%- endif -%}
        {%- if section.settings.boutique_label != blank -%}
          <p class="pa-boutique__boutique-label">{{ section.settings.boutique_label }}</p>
        {%- endif -%}
      </div>

      {%- if section.settings.address != blank -%}
        <div class="pa-boutique__block">
          <p class="pa-boutique__address">{{ section.settings.address | newline_to_br }}</p>
        </div>
      {%- endif -%}

      {%- if section.settings.hours_weekday != blank or section.settings.hours_weekend != blank -%}
        <div class="pa-boutique__block">
          <p class="pa-boutique__block-label">Opening Hours</p>
          {%- if section.settings.hours_weekday != blank -%}
            <p class="pa-boutique__text">{{ section.settings.hours_weekday }}</p>
          {%- endif -%}
          {%- if section.settings.hours_weekend != blank -%}
            <p class="pa-boutique__text">{{ section.settings.hours_weekend }}</p>
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- if section.settings.phone != blank or section.settings.email != blank -%}
        <div class="pa-boutique__block">
          <p class="pa-boutique__block-label">Contact</p>
          {%- if section.settings.phone != blank -%}
            <p class="pa-boutique__text">
              <a href="tel:{{ section.settings.phone | remove: ' ' }}" class="pa-boutique__link">
                {{ section.settings.phone }}
              </a>
            </p>
          {%- endif -%}
          {%- if section.settings.email != blank -%}
            <p class="pa-boutique__text">
              <a href="mailto:{{ section.settings.email }}" class="pa-boutique__link">
                {{ section.settings.email }}
              </a>
            </p>
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- if section.settings.services != blank -%}
        <div class="pa-boutique__block">
          <p class="pa-boutique__block-label">Services</p>
          <p class="pa-boutique__services">{{ section.settings.services }}</p>
        </div>
      {%- endif -%}

      {%- if section.settings.directions_url != blank -%}
        <a
          href="{{ section.settings.directions_url }}"
          class="pa-boutique__directions-btn"
          target="_blank"
          rel="noopener noreferrer"
        >
          {{ section.settings.directions_label | default: 'GET DIRECTIONS' }}
        </a>
      {%- endif -%}

    </div>
  </div>
</div>

<style>
  .pa-boutique__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 480px;
  }

  /* ── Map ── */
  .pa-boutique__map {
    position: relative;
    min-height: 400px;
  }

  .pa-boutique__map iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .pa-boutique__map-placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 100%;
    background: #e8e8e8;
    color: #999;
    font-size: 13px;
    padding: 24px;
    text-align: center;
  }

  /* ── Info panel ── */
  .pa-boutique__info {
    display: flex;
    flex-direction: column;
    gap: 28px;
    padding: 48px 56px;
    background: var(--color-background);
  }

  /* Brand / logo */
  .pa-boutique__brand {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .pa-boutique__logo {
    height: auto;
    max-width: 180px;
    width: auto;
  }

  .pa-boutique__shop-name {
    font-size: 28px;
    font-weight: 400;
    font-style: italic;
    letter-spacing: 0.02em;
    color: var(--color-foreground);
  }

  .pa-boutique__boutique-label {
    margin: 0;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-accent, var(--color-link));
  }

  /* Info blocks */
  .pa-boutique__block {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .pa-boutique__block-label {
    margin: 0;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent, var(--color-link));
  }

  .pa-boutique__address,
  .pa-boutique__text,
  .pa-boutique__services {
    margin: 0;
    font-size: 13px;
    font-weight: 400;
    line-height: 1.6;
    color: var(--color-foreground);
  }

  .pa-boutique__services {
    color: rgb(var(--color-foreground-rgb, var(--color-foreground)) / 0.7);
  }

  .pa-boutique__link {
    color: inherit;
    text-decoration: none;
  }

  .pa-boutique__link:hover {
    text-decoration: underline;
  }

  /* Directions button */
  .pa-boutique__directions-btn {
    display: inline-block;
    align-self: stretch;
    padding: 14px 28px;
    text-align: center;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-foreground);
    background: transparent;
    border: 1px solid var(--color-foreground);
    border-radius: 4px;
    text-decoration: none;
    transition: background 0.2s ease, color 0.2s ease;
    margin-top: auto;
  }

  .pa-boutique__directions-btn:hover {
    background: var(--color-foreground);
    color: var(--color-background);
  }

  /* ── Mobile ── */
  @media (max-width: 749px) {
    .pa-boutique__inner {
      grid-template-columns: 1fr;
    }

    .pa-boutique__map {
      min-height: 280px;
    }

    .pa-boutique__info {
      padding: 36px 24px;
      gap: 24px;
    }
  }
</style>

{% schema %}
{
  "name": "PA Boutique",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Map"
    },
    {
      "type": "text",
      "id": "map_embed_url",
      "label": "Google Maps Embed URL",
      "info": "Go to Google Maps → Share → Embed a map → copy the src URL"
    },
    {
      "type": "header",
      "content": "Brand"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo Image"
    },
    {
      "type": "text",
      "id": "boutique_label",
      "label": "Boutique Label",
      "default": "JUMEIRAH BOUTIQUE"
    },
    {
      "type": "header",
      "content": "Address"
    },
    {
      "type": "textarea",
      "id": "address",
      "label": "Address",
      "default": "[Boutique Address Line 1]\nJumeirah, Dubai, UAE"
    },
    {
      "type": "header",
      "content": "Opening Hours"
    },
    {
      "type": "text",
      "id": "hours_weekday",
      "label": "Monday – Saturday",
      "default": "Monday – Saturday: 10:00am – 8:00pm"
    },
    {
      "type": "text",
      "id": "hours_weekend",
      "label": "Sunday",
      "default": "Sunday: 12:00pm – 6:00pm"
    },
    {
      "type": "header",
      "content": "Contact"
    },
    {
      "type": "text",
      "id": "phone",
      "label": "Phone",
      "default": "+971 4 XXX XXXX"
    },
    {
      "type": "text",
      "id": "email",
      "label": "Email",
      "default": "concierge@poloavenue.ae"
    },
    {
      "type": "header",
      "content": "Services"
    },
    {
      "type": "text",
      "id": "services",
      "label": "Services (comma separated)",
      "default": "Personal Styling · Gift Wrapping · Alterations · Authentication · VIP Private Viewing"
    },
    {
      "type": "header",
      "content": "Directions Button"
    },
    {
      "type": "text",
      "id": "directions_label",
      "label": "Button Label",
      "default": "GET DIRECTIONS"
    },
    {
      "type": "url",
      "id": "directions_url",
      "label": "Google Maps Link"
    },
    {
      "type": "header",
      "content": "Section Layout"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "PA Boutique"
    }
  ]
}
{% endschema %}
