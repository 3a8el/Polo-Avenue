<style>
  /* ── Trust Badges ── */
  .pa-trust-badges {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 8px;
    margin-top: 4px;
  }

  .pa-trust-badge {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    padding: 12px 8px;
    border: 1px solid var(--color-border, rgba(0,0,0,0.1));
    border-radius: 4px;
    text-align: center;
  }

  .pa-trust-badge__icon {
    font-size: 18px;
    line-height: 1;
    opacity: 0.7;
  }

  .pa-trust-badge__label {
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-foreground);
    opacity: 0.7;
  }

  /* ── VAT Note ── */
  .pa-vat-note {
    font-size: 12px;
    color: var(--color-foreground);
    opacity: 0.6;
    margin: 0;
  }
</style>

