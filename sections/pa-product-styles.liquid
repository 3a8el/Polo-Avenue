<style>
  /* ── Trust Badges ── */
  .pa-trust-badges {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 8px;
    margin-top: 4px;
  }

  .pa-trust-badge {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    padding: 12px 8px;
    border: 1px solid var(--color-border, rgba(0,0,0,0.1));
    border-radius: 4px;
    text-align: center;
  }

  .pa-trust-badge__icon {
    font-size: 18px;
    line-height: 1;
    opacity: 0.7;
  }

  .pa-trust-badge__label {
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-foreground);
    opacity: 0.7;
  }

  /* ── VAT Note ── */
  .pa-vat-note {
    font-size: 12px;
    color: var(--color-foreground);
    opacity: 0.6;
    margin: 0;
  }

  /* ── Wishlist Heart Icon ── */
  .swym-button svg,
  .swym-wishlist-btn svg,
  [data-swym-add-to-wishlist] svg,
  .card-wrapper .swym-button svg,
  .card-wrapper .swym-wishlist-btn svg {
    fill: #EF4B37 !important;
    stroke: #EF4B37 !important;
    color: #EF4B37 !important;
  }

  .swym-button,
  .swym-wishlist-btn,
  [data-swym-add-to-wishlist] {
    color: #EF4B37 !important;
  }

  /* ── Quick Add Button ── */
  add-to-cart-component,
  quick-add-component,
  .quick-add,
  .quick-add__submit,
  [id*="QuickAdd"] {
    backdrop-filter: none !important;
    -webkit-backdrop-filter: none !important;
    background: transparent !important;
  }

  quick-add-component .quick-add__button,
  quick-add-component .quick-add__button--add,
  .card-wrapper .quick-add__button,
  .card-wrapper .quick-add__button--add,
  .product-card-wrapper .quick-add__button,
  .quick-add__button,
  .quick-add__button--add,
  button.add-to-cart-button {
    width: auto !important;
    min-width: 100px !important;
    max-width: 140px !important;
    background: #ffffff !important;
    background-image: none !important;
    backdrop-filter: none !important;
    -webkit-backdrop-filter: none !important;
    filter: none !important;
    color: #1A1A1A !important;
    border: 1px solid #E5E5E5 !important;
    border-radius: 4px !important;
    font-size: 11px !important;
    padding: 8px 16px !important;
    box-shadow: none !important;
  }
</style>

{% schema %}
{
  "name": "PA Product Styles",
  "tag": null,
  "settings": [],
  "presets": [{ "name": "PA Product Styles" }]
}
{% endschema %}
