{% doc %}
  @prompt
    generate a section with h3, h4, text, button, andthe background of this image will be a text that i enter, the h3 in this section is not the same size as the h3 in previouse sectiuons, the heading is size 10px,
    and the subheading is size 44px, make the text background block width controlable, make this block width to full width
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-text-bg-block-{{ ai_gen_id }} {
    {% comment %} position: relative; {% endcomment %}
    width: 100%;
    max-width: 100%;
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_horizontal }}px {{ block.settings.padding_bottom }}px;
    overflow: hidden;
    display: block;
  }

  .ai-text-bg-block__background-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 0;
    pointer-events: none;
  }

  .ai-text-bg-block__background-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.background_text_size }}px;
    font-weight: {{ block.settings.background_text_weight }};
    color: {{ block.settings.background_text_color }};
    opacity: {{ block.settings.background_text_opacity | divided_by: 100.0 }};
    white-space: nowrap;
    text-transform: {{ block.settings.background_text_transform }};
    line-height: 1;
    max-width: {{ block.settings.background_text_width }}%;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .ai-text-bg-block__content-{{ ai_gen_id }} {
    position: relative;
    z-index: 1;
    max-width: {{ block.settings.content_max_width }}px;
    margin: 0 auto;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-text-bg-block__heading-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.heading_spacing }}px;
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    line-height: 1.2;
  }

  .ai-text-bg-block__subheading-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.subheading_spacing }}px;
    color: {{ block.settings.subheading_color }};
    font-size: {{ block.settings.subheading_size }}px;
    line-height: 1.3;
  }

  .ai-text-bg-block__text-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.text_spacing }}px;
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.6;
  }

  .ai-text-bg-block__button-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: 11px;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.3s ease;
    font-weight:600;
  }

  .ai-text-bg-block__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-text-bg-block__background-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.background_text_size | times: 0.3 }}px;
    }

    .ai-text-bg-block__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
    }

    .ai-text-bg-block__subheading-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheading_size | times: 0.8 }}px;
    }

    .ai-text-bg-block__text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-text-bg-block-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-text-bg-block__background-{{ ai_gen_id }}">
    {% if block.settings.background_text != blank %}
      <div class="ai-text-bg-block__background-text-{{ ai_gen_id }}">
        {{ block.settings.background_text }}
      </div>
    {% endif %}
  </div>

  <div class="ai-text-bg-block__content-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h3 class="ai-text-bg-block__heading-{{ ai_gen_id }}">
        {{ block.settings.heading }}
      </h3>
    {% endif %}

    {% if block.settings.subheading != blank %}
      <h4 class="ai-text-bg-block__subheading-{{ ai_gen_id }}">
        {{ block.settings.subheading }}
      </h4>
    {% endif %}

    {% if block.settings.text != blank %}
      <div class="ai-text-bg-block__text-{{ ai_gen_id }}">
        {{ block.settings.text }}
      </div>
    {% endif %}

    {% if block.settings.button_text != blank %}
      <a
        href="{{ block.settings.button_link }}"
        class="ai-text-bg-block__button-{{ ai_gen_id }}"
      >
        {{ block.settings.button_text }}
      </a>
    {% endif %}
  </div>
</div>

