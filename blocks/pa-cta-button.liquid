<a
  href="{{ block.settings.url | default: '#' }}"
  class="pa-cta-btn"
  {{ block.shopify_attributes }}
>
  <span class="pa-cta-btn__label">{{ block.settings.label }}</span>
  <span class="pa-cta-btn__icon" aria-hidden="true">
    <svg width="16" height="8" viewBox="0 0 16 8" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M0 4H14M14 4L11 1M14 4L11 7" stroke="#EF4B37" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </span>
</a>

<style>
  .pa-cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-family: 'Montserrat', var(--font-body--family), sans-serif;
    font-size: 10px;
    font-weight: 600;
    line-height: 1;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: #EF4B37;
    text-decoration: none;
  }

  .pa-cta-btn:hover { opacity: 0.8; }

  .pa-cta-btn__icon {
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }
</style>

{% schema %}
{
  "name": "PA CTA Button",
  "settings": [
    { "type": "text", "id": "label", "label": "Label", "default": "SHOP NOW" },
    { "type": "url", "id": "url", "label": "Link URL" }
  ],
  "presets": [{ "name": "PA CTA Button" }]
}
{% endschema %}
