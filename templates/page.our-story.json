        "para2": {
          "type": "paragraph",
          "settings": {
            "paragraph": "Founded in 1987 by luxury pioneer John Obayuwana, Polo Luxury Group has built a legacy defined by excellence, discretion, craftsmanship, and an uncompromising understanding of luxury clientele across West Africa."
