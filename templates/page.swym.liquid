{{ page.content }}

<style>
  /* ── Swym Wishlist Page Overrides ── */

  /* 1. Hide the heart icon after the "My Wishlist" heading */
  #swym-wishlist-title svg,
  .swym-storefront-layout-title svg {
    display: none !important;
  }

  /* 2. Vendor line */
  .pa-swym-vendor {
    display: block;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #EF4B37;
    margin: 0 0 4px;
  }

  /* Title + price row */
  .swym-storefront-layout-grid-item-content {
    display: flex !important;
    flex-direction: column !important;
  }

  .pa-swym-title-price-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 8px;
  }

  /* 3. Card container — remove Swym default styles */
  .swym-storefront-layout-grid-item {
    background: transparent !important;
    border: none !important;
    box-shadow: none !important;
    border-radius: 0 !important;
    padding: 0 !important;
    position: relative !important;
  }

  /* 3. Hide the three-dot options button */
  .swym-storefront-layout-grid-item-option-button {
    display: none !important;
  }

  /* 4. Product image — portrait aspect ratio matching site cards */
  .swym-storefront-layout-grid-item-image-container {
    display: block !important;
    width: 100% !important;
    overflow: hidden !important;
  }

  .swym-storefront-layout-grid-item-image {
    width: 100% !important;
    aspect-ratio: 3 / 4 !important;
    object-fit: cover !important;
    display: block !important;
    border-radius: 0 !important;
  }

  /* 5. Content area */
  .swym-storefront-layout-grid-item-content {
    padding: 8px 0 0 !important;
    background: transparent !important;
  }

  /* 6. Title + price row */
  .swym-storefront-layout-grid-item-price-variant {
    display: flex !important;
    align-items: baseline !important;
    justify-content: space-between !important;
    gap: 8px !important;
    margin-top: 2px !important;
  }

  /* 7. Product title */
  .swym-storefront-layout-grid-item-title {
    font-size: 1rem !important;
    font-weight: 400 !important;
    color: var(--color-foreground) !important;
    text-decoration: none !important;
    letter-spacing: normal !important;
    text-transform: none !important;
    margin: 0 !important;
    flex: 1 !important;
    min-width: 0 !important;
    overflow: hidden !important;
    text-overflow: ellipsis !important;
    white-space: nowrap !important;
  }

  /* 8. Price */
  .swym-storefront-layout-grid-item-final-price {
    font-size: 1rem !important;
    color: var(--color-foreground) !important;
    font-weight: 400 !important;
    white-space: nowrap !important;
    flex-shrink: 0 !important;
  }

  /* 9. Hide the pipe divider and variant info */
  .swym-storefront-layout-price-devider,
  .swym-storefront-layout-grid-item-variants-container,
  .swym-storefront-layout-grid-item-price-variant {
    display: none !important;
  }

  /* 10. Add to Cart button — match site style */
  .swym-storefront-layout-grid-item-add-to-cart-button {
    width: 100% !important;
    background: #1A1A1A !important;
    color: #fff !important;
    border: none !important;
    border-radius: 4px !important;
    font-size: 11px !important;
    font-weight: 700 !important;
    letter-spacing: 0.12em !important;
    text-transform: uppercase !important;
    padding: 12px 0 !important;
    margin-top: 10px !important;
    cursor: pointer !important;
    transition: background 0.2s ease !important;
  }

  .swym-storefront-layout-grid-item-add-to-cart-button:hover {
    background: #333 !important;
  }
</style>

<script>
(function () {
  const vendorCache = {};

  async function getVendor(productUrl) {
    try {
      const match = productUrl.match(/\/products\/([^?/]+)/);
      if (!match) return null;
      const handle = match[1];
      if (vendorCache[handle] !== undefined) return vendorCache[handle];
      const res = await fetch('/products/' + handle + '.js');
      const data = await res.json();
      vendorCache[handle] = data.vendor || null;
      return vendorCache[handle];
    } catch (e) {
      return null;
    }
  }

  function processCards() {
    const cards = document.querySelectorAll('.swym-storefront-layout-grid-item:not([data-pa-processed])');
    cards.forEach(async (card) => {
      card.setAttribute('data-pa-processed', '1');
      const link = card.querySelector('.swym-storefront-layout-grid-item-image-container');
      const content = card.querySelector('.swym-storefront-layout-grid-item-content');
      const titleEl = card.querySelector('.swym-storefront-layout-grid-item-title');
      const priceEl = card.querySelector('.swym-storefront-layout-grid-item-final-price');
      if (!content || !titleEl || !priceEl) return;

      // Fetch vendor
      const vendor = link ? await getVendor(link.href) : null;

      // Inject vendor line
      if (vendor && !card.querySelector('.pa-swym-vendor')) {
        const vendorEl = document.createElement('span');
        vendorEl.className = 'pa-swym-vendor';
        vendorEl.textContent = vendor;
        content.insertBefore(vendorEl, content.firstChild);
      }

      // Wrap title + price in a flex row
      if (!card.querySelector('.pa-swym-title-price-row')) {
        const row = document.createElement('div');
        row.className = 'pa-swym-title-price-row';
        titleEl.parentNode.insertBefore(row, titleEl);
        row.appendChild(titleEl);
        row.appendChild(priceEl);
      }
    });
  }

  // Run on Swym render and on DOM mutations
  const observer = new MutationObserver(() => processCards());
  observer.observe(document.body, { childList: true, subtree: true });
  // Also run after a short delay as a fallback
  setTimeout(processCards, 1500);
  setTimeout(processCards, 3000);
})();
</script>
